  file_change {
    absolute_path_uri: "file:///src/components/FreshBakery.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { useState } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { Sparkles, ShoppingBag, Eye, Heart, Check, Trash2, ArrowUpRight } from \"lucide-react\";\nimport { BakeryProduct } from \"../types\";\n\nconst BAKERY_PRODUCTS: BakeryProduct[] = [\n  {\n    id: \"bakery-1\",\n    name: \"The Signature Palette Knife Floral\",\n    description: \"Our viral masterpiece. Gorgeous hand-piped heavy buttercream layers adorned with custom impasto-style palette knife blooms, raspberry curd fillings, and soft pistachio cake crumbs.\",\n    price: \"\342\202\2712,400\",\n    tag: \"MOST VIRAL ON INSTAGRAM\",\n    image: \"https://images.unsplash.com/photo-1535141192574-5d4897c13636?q=80&w=1200&auto=format&fit=crop\",\n    flavorProfile: [\"Madagascar Vanilla\", \"Raspberry Tangy Curd\", \"Rose-Salt Buttercream\"],\n    textureNotes: \"Extremely rich crumb structure with fluffy, whipped organic butter finishes.\",\n    isPopular: true\n  },\n  {\n    id: \"bakery-2\",\n    name: \"The Concrete Hazelnut Crunch\",\n    description: \"A minimalist sculpt for the ultra-modern. Textured gray concrete finishes holding a heart of loaded hazelnut praline crumbles, dark Belgian chocolate ganache, and crisp wafer layers.\",\n    price: \"\342\202\2712,800\",\n    tag: \"CHEF\'S FAVORITE\",\n    image: \"https://images.unsplash.com/photo-1542826438-bd32f43d626f?q=80&w=1200&auto=format&fit=crop\",\n    flavorProfile: [\"72% Belgian Cocoa\", \"Roasted Piedmont Hazelnut\", \"Fleur de Sel Crunch\"],\n    textureNotes: \"Varying ratios of brittle crunch holding together liquid chocolate core.\",\n    isPopular: true\n  },\n  {\n    id: \"bakery-3\",\n    name: \"The Velvet Cocoa Drip\",\n    description: \"Deep, chocolate velvet cake sprayed using premium cocoa butter nozzles. Draped in a silky chocolate ganache slide and topped with edible gold leaf accents.\",\n    price: \"\342\202\2712,600\",\n    tag: \"CHOCOLATE HEAVEN\",\n    image: \"https://images.unsplash.com/photo-1578985545062-69928b1d9587?q=80&w=1200&auto=format&fit=crop\",\n    flavorProfile: [\"Dark Cocoa Butter Spray\", \"Silky Ganache Drip\", \"Espresso-soaked sponge\"],\n    textureNotes: \"A melt-in-your-mouth decadent experience with heavy velvet finish.\",\n    isPopular: false\n  }\n];\n\nexport default function FreshBakery() {\n  const [selectedCake, setSelectedCake] = useState<BakeryProduct | null>(null);\n  const [customWeight, setCustomWeight] = useState<string>(\"1.0 kg\");\n  const [customDecoration, setCustomDecoration] = useState<string>(\"Standard Elegance\");\n  const [customFlavor, setCustomFlavor] = useState<string>(\"\");\n  const [submittingOrder, setSubmittingOrder] = useState(false);\n  const [orderSlip, setOrderSlip] = useState<any | null>(null);\n\n  const weights = [\"0.5 kg\", \"1.0 kg\", \"1.5 kg\", \"2.0 kg\", \"Custom Tiered\"];\n  const decorationStyles = [\n    \"Standard Elegance\",\n    \"Heavily Textured palette-knife\",\n    \"Minimalist Concrete\",\n    \"Gilded Gold Leaf Flakes\"\n  ];\n\n  const handleOpenConfigurator = (cake: BakeryProduct) => {\n    setSelectedCake(cake);\n    setCustomWeight(\"1.0 kg\");\n    setCustomDecoration(\"Standard Elegance\");\n    setCustomFlavor(cake.flavorProfile[0]);\n    setOrderSlip(null);\n  };\n\n  const calculateFinalPrice = () => {\n    if (!selectedCake) return 0;\n    const base = parseInt(selectedCake.price.replace(/[^\\d]/g, \"\"), 10);\n    let multiplier = 1;\n\n    if (customWeight === \"0.5 kg\") multiplier = 0.6;\n    if (customWeight === \"1.5 kg\") multiplier = 1.5;\n    if (customWeight === \"2.0 kg\") multiplier = 2.0;\n    if (customWeight === \"Custom Tiered\") multiplier = 3.5;\n\n    let decorAdd = 0;\n    if (customDecoration === \"Heavily Textured palette-knife\") decorAdd = 400;\n    if (customDecoration === \"Gilded Gold Leaf Flakes\") decorAdd = 600;\n    if (customDecoration === \"Minimalist Concrete\") decorAdd = 200;\n\n    return Math.round(base * multiplier + decorAdd);\n  };\n\n  const handleSubmitInquiry = (e: any) => {\n    e.preventDefault();\n    setSubmittingOrder(true);\n    \n    const clientName = e.target.fullName.value;\n    const clientPhone = e.target.phone.value;\n    const clientDate = e.target.pickupDate.value;\n    const clientNote = e.target.designNotes.value;\n\n    setTimeout(() => {\n      setOrderSlip({\n        orderId: `MC-${Math.floor(1000 + Math.random() * 9000)}`,\n        cakeName: selectedCake?.name,\n        clientName,\n        clientPhone,\n        clientDate,\n        customWeight,\n        customDecoration,\n        customFlavor,\n        finalPrice: calculateFinalPrice(),\n        clientNote\n      });\n      setSubmittingOrder(false);\n    }, 1500);\n  };\n\n  return (\n    <section id=\"bakery\" className=\"py-24 md:py-32 bg-cream relative\">\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12\">\n        \n        {/* Section Title */}\n        <div className=\"max-w-2xl text-left mb-16 md:mb-20\">\n          <span className=\"text-xs font-semibold uppercase tracking-[0.25em] text-mauve font-sans block mb-3\">\n            \342\234\246 HIGH-END CURATED BAKERY\n          </span>\n          <h2 className=\"font-serif text-4xl sm:text-5xl md:text-6xl font-normal leading-tight text-plum tracking-tight\">\n            Order High-Texture, Visceral Sculpted Cakes\n          </h2>\n          <p className=\"mt-6 text-sm md:text-base font-light text-plum/75 font-sans leading-relaxed\">\n            Baked raw and freshly sculpted in our private kitchen using local ingredients, premium French butter, and organic fruit purees. Available for local pickup with 48 hours notice.\n          </p>\n        </div>\n\n        {/* Products Showcase Split Row */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-start\">\n          \n          {/* Left: The Cakes List */}\n          <div className=\"lg:col-span-7 space-y-12\">\n            {BAKERY_PRODUCTS.map((cake, idx) => (\n              <motion.div\n                key={cake.id}\n                initial={{ opacity: 0, x: -30 }}\n                whileInView={{ opacity: 1, x: 0 }}\n                viewport={{ once: true, margin: \"-100px\" }}\n                transition={{ duration: 0.8, ease: [0.76, 0, 0.24, 1] }}\n                className=\"group grid grid-cols-1 md:grid-cols-12 gap-6 items-center bg-surface-white p-6 border border-plum/10 hover:border-plum transition-all duration-500 rounded-2xl\"\n              >\n                {/* Product Image Panel */}\n                <div className=\"md:col-span-5 relative aspect-[1/1] w-full overflow-hidden rounded-xl bg-plum/5\">\n                  <img\n                    src={cake.image}\n                    alt={cake.name}\n                    referrerPolicy=\"no-referrer\"\n                    className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-[cubic-bezier(0.76,0,0.24,1)]\"\n                  />\n                  {cake.isPopular && (\n                    <div className=\"absolute bottom-3 left-3 bg-plum text-cream text-[9px] font-bold uppercase tracking-widest px-2.5 py-1 z-20 rounded-full flex items-center gap-1\">\n                      <Sparkles className=\"w-2.5 h-2.5 fill-cream\" />\n                      <span>VIRAL SELLER</span>\n                    </div>\n                  )}\n                </div>\n\n                {/* Info and buttons */}\n                <div className=\"md:col-span-7 flex flex-col justify-between h-full text-left md:pl-4\">\n                  <div>\n                    <span className=\"text-[10px] font-bold uppercase tracking-[0.15em] text-mauve\">\n                      {cake.isPopular ? \"Highly Demanded\" : \"Limited Series\"}\n                    </span>\n                    <h3 className=\"font-serif text-2xl text-plum mt-1\">\n                      {cake.name}\n                    </h3>\n                    <p className=\"text-[12px] font-mono text-plum/65 mt-2 flex items-center gap-1.5\">\n                      <span>Base price: {cake.price}</span>\n                      <span className=\"w-1 h-1 bg-plum/25 rounded-full\" />\n                      <span>{cake.flavorProfile[0]} focused</span>\n                    </p>\n                    <p className=\"text-sm font-light text-plum/85 mt-3 leading-relaxed font-sans\">\n                      {cake.description}\n                    </p>\n                  </div>\n\n                  <div className=\"mt-6 flex items-center justify-between gap-4\">\n                    <button\n                      onClick={() => handleOpenConfigurator(cake)}\n                      className=\"px-6 py-3 bg-plum text-cream text-[11px] font-bold uppercase tracking-widest rounded-full hover:bg-mauve hover:text-plum transition-all duration-500 flex items-center gap-2 cursor-pointer group\"\n                    >\n                      <span>Configure & Order</span>\n                      <ArrowUpRight className=\"w-3.5 h-3.5 text-cream group-hover:text-plum group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform\" />\n                    </button>\n                  </div>\n                </div>\n              </motion.div>\n            ))}\n          </div>\n\n          {/* Right: Fine Print / Features & Design values (45%) */}\n          <div className=\"lg:col-span-5 sticky top-28 bg-plum text-cream p-8 md:p-10 rounded-2xl border border-cream/5 flex flex-col items-start text-left shadow-[0_24px_50px_rgba(33,20,38,0.15)]\">\n            <span className=\"text-[10px] uppercase tracking-widest text-mauve font-sans font-semibold mb-3\">\n              \342\234\246 ARTISAN PROTOCOL\n            </span>\n            <h3 className=\"font-serif text-3xl text-cream font-light mb-6\">\n              Why Our Cakes Melt Hearts\n            </h3>\n\n            <div className=\"space-y-6 w-full\">\n              <div className=\"border-b border-cream/10 pb-4\">\n                <h4 className=\"text-sm font-semibold uppercase tracking-wider text-cream font-sans\">\n                  01. Custom Palette Sculpting\n                </h4>\n                <p className=\"text-xs font-light text-cream/70 mt-1 leading-relaxed\">\n                  Unlike traditional piped borders, we sculpt with heavy-set cocoa butter ganache and cold buttercream sheets using artist spatulas for visual texture depth.\n                </p>\n              </div>\n\n              <div className=\"border-b border-cream/10 pb-4\">\n                <h4 className=\"text-sm font-semibold uppercase tracking-wider text-cream font-sans\">\n                  02. Layer-by-Layer Balancing\n                </h4>\n                <p className=\"text-xs font-light text-cream/70 mt-1 leading-relaxed\">\n                  Four thin layers of premium vanilla or cocoa sponge balanced against three custom infusions, resulting in a dense yet cloud-like consistency.\n                </p>\n              </div>\n\n              <div>\n                <h4 className=\"text-sm font-semibold uppercase tracking-wider text-cream font-sans\">\n                  03. Handpicked Sourcing\n                </h4>\n                <p className=\"text-xs font-light text-cream/70 mt-1 leading-relaxed\">\n                  We use organic cardamom from Kerala, single-origin Belgian chocolate, and vine-ripened local raspberries to avoid processed syrup artificial notes.\n                </p>\n              </div>\n            </div>\n\n            <div className=\"mt-8 pt-6 border-t border-cream/10 w-full text-center bg-cream/5 rounded-xl p-4 flex gap-4 items-center\">\n              <div className=\"text-left\">\n                <p className=\"text-[10px] uppercase tracking-widest text-[#D4AF37] font-semibold\">\n                  ORDER ASSURANCE\n                </p>\n                <p className=\"text-xs text-cream/80 mt-1\">\n                  Secure local pickups supported. Questions or bespoke requests? Mail Mahek Baldota at <span className=\"underline text-cream whitespace-nowrap\">orders@mummascake.com</span>\n                </p>\n              </div>\n            </div>\n          </div>\n\n        </div>\n\n      </div>\n\n      {/* Bakery Configurator & Ordering Drawer Modal */}\n      <AnimatePresence>\n        {selectedCake && (\n          <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n            <motion.div\n              initial={{ opacity: 0 }}\n              animate={{ opacity: 1 }}\n              exit={{ opacity: 0 }}\n              onClick={() => setSelectedCake(null)}\n              className=\"absolute inset-0 bg-plum/75 backdrop-blur-sm\"\n            />\n\n            <motion.div\n              initial={{ scale: 0.95, opacity: 0, y: 30 }}\n              animate={{ scale: 1, opacity: 1, y: 0 }}\n              exit={{ scale: 0.95, opacity: 0, y: 30 }}\n              transition={{ duration: 0.5, ease: [0.76, 0, 0.24, 1] }}\n              className=\"relative w-full max-w-4xl bg-cream p-6 md:p-8 border border-plum/10 rounded-2xl shadow-[0_32px_64px_rgba(33,20,38,0.25)] z-10 max-h-[90vh] overflow-y-auto\"\n            >\n              <button\n                onClick={() => setSelectedCake(null)}\n                className=\"absolute top-6 right-6 p-2 bg-plum/5 hover:bg-plum/10 text-plum rounded-full transition-colors\"\n                placeholder=\"Close order modal\"\n              >\n                <XButton />\n              </button>\n\n              <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 text-left mt-4\">\n                \n                {/* Left side: Visual & Custom Details Slip */}\n                <div className=\"lg:col-span-5 flex flex-col\">\n                  <div className=\"aspect-[4/3] w-full rounded-xl overflow-hidden bg-plum/5\">\n                    <img\n                      src={selectedCake.image}\n                      alt={selectedCake.name}\n                      referrerPolicy=\"no-referrer\"\n                      className=\"w-full h-full object-cover\"\n                    />\n                  </div>\n\n                  <div className=\"mt-6\">\n                    <span className=\"text-[10px] font-bold uppercase tracking-[0.15em] text-mauve\">\n                      SELECTED MODEL\n                    </span>\n                    <h3 className=\"font-serif text-2xl text-plum mt-1\">{selectedCake.name}</h3>\n                    <p className=\"text-xs font-light text-plum/75 mt-3 leading-relaxed font-sans\">\n                      {selectedCake.description}\n                    </p>\n                  </div>\n\n                  {/* Real-time calculated receipt slip */}\n                  <div className=\"mt-auto pt-6 border-t border-plum/10 bg-plum/5 p-4 rounded-xl border border-plum/5\">\n                    <p className=\"text-[10px] uppercase tracking-widest text-mauve font-semibold\">\n                      REALTIME INVOICE ESTIMATE\n                    </p>\n                    <div className=\"flex justify-between items-baseline mt-2\">\n                      <span className=\"text-xs font-mono text-plum/70\">Estimated order sum:</span>\n                      <span className=\"font-serif text-2xl text-plum\">\342\202\271{calculateFinalPrice().toLocaleString()}</span>\n                    </div>\n                    <p className=\"text-[10px] text-plum/60 mt-1.5 font-sans\">\n                      Contains custom decoration surcharges if selected. Taxes included.\n                    </p>\n                  </div>\n                </div>\n\n                {/* Right side: Interactive Form Controls & Custom Sliders */}\n                <div className=\"lg:col-span-7 flex flex-col justify-between border-t lg:border-t-0 lg:border-l border-plum/10 pt-6 lg:pt-0 lg:pl-8\">\n                  {orderSlip ? (\n                    /* Inquiry Slip Receipt Success Animation */\n                    <motion.div\n                      initial={{ scale: 0.95, opacity: 0 }}\n                      animate={{ scale: 1, opacity: 1 }}\n                      className=\"flex flex-col h-full justify-center text-left py-6\"\n                    >\n                      <div className=\"w-12 h-12 bg-plum text-cream rounded-full flex items-center justify-center mb-4\">\n                        <Check className=\"w-6 h-6 text-cream\" />\n                      </div>\n                      <h4 className=\"font-serif text-2xl text-plum\">\n                        Order Inquiry Logged!\n                      </h4>\n                      <p className=\"text-xs font-light font-sans text-plum/75 mt-2 max-w-md\">\n                        Your custom gourmet cake inquiry has been successfully transmitted directly to Mahek Baldota\'s orders desk. A pastry chef will ring you within 4 business hours to confirm your custom decoration sketch and schedule fulfillment.\n                      </p>\n\n                      {/* Printable visual receipt card */}\n                      <div className=\"mt-6 border-2 border-dashed border-plum/20 bg-surface-white p-5 rounded-xl font-mono text-xs text-plum/85 space-y-2\">\n                        <p className=\"font-bold border-b border-plum/10 pb-2 text-sm text-plum flex justify-between\">\n                          <span>MUMMA\'S CAKETICKET</span>\n                          <span className=\"text-mauve\">{orderSlip.orderId}</span>\n                        </p>\n                        <p><strong>Cake:</strong> {orderSlip.cakeName}</p>\n                        <p><strong>Client:</strong> {orderSlip.clientName}</p>\n                        <p><strong>Fulfillment Date:</strong> {orderSlip.clientDate}</p>\n                        <p><strong>Weight Config:</strong> {orderSlip.customWeight}</p>\n                        <p><strong>Decoration:</strong> {orderSlip.customDecoration}</p>\n                        <p><strong>Flavor Focus:</strong> {orderSlip.customFlavor}</p>\n                        <p className=\"border-t border-plum/10 pt-2 text-sm text-plum\">\n                          <strong>TOTAL PRICE:</strong> <span className=\"font-sans font-bold float-right\">\342\202\271{orderSlip.finalPrice.toLocaleString()}</span>\n                        </p>\n                      </div>\n\n                      <button\n                        onClick={() => setSelectedCake(null)}\n                        className=\"mt-6 w-full py-3 bg-plum text-cream text-[11px] font-bold uppercase tracking-widest rounded-full hover:bg-mauve\"\n                      >\n                        Back to Bakery Catalog\n                      </button>\n                    </motion.div>\n                  ) : (\n                    /* The Configuration Form */\n                    <form onSubmit={handleSubmitInquiry} className=\"space-y-5\">\n                      {/* Weight Select Row */}\n                      <div>\n                        <label className=\"text-[10px] uppercase tracking-widest text-mauve font-sans font-bold block mb-2\">\n                          1\357\270\217\342\203\243 SELECT WEIGHT / SIZE\n                        </label>\n                        <div className=\"flex flex-wrap gap-2\">\n                          {weights.map((w) => (\n                            <button\n                              type=\"button\"\n                              key={w}\n                              onClick={() => setCustomWeight(w)}\n                              className={`px-3 py-2 rounded-lg text-xs tracking-wide transition-all ${\n                                customWeight === w\n                                  ? \"bg-plum text-cream font-semibold\"\n                                  : \"bg-surface-white hover:bg-plum/5 text-plum border border-plum/10\"\n                              }`}\n                            >\n                              {w}\n                            </button>\n                          ))}\n                        </div>\n                      </div>\n\n                      {/* Flavor Select Option */}\n                      <div>\n                        <label className=\"text-[10px] uppercase tracking-widest text-mauve font-sans font-bold block mb-2\">\n                          2\357\270\217\342\203\243 FLAVOR PROFILE SPECIALTY\n                        </label>\n                        <div className=\"flex flex-wrap gap-2\">\n                          {selectedCake.flavorProfile.map((fl) => (\n                            <button\n                              type=\"button\"\n                              key={fl}\n                              onClick={() => setCustomFlavor(fl)}\n                              className={`px-3 py-2 rounded-lg text-xs tracking-wide transition-all ${\n                                customFlavor === fl\n                                  ? \"bg-plum text-cream font-semibold\"\n                                  : \"bg-surface-white hover:bg-plum/5 text-plum border border-plum/10\"\n                              }`}\n                            >\n                              {fl}\n                            </button>\n                          ))}\n                        </div>\n                      </div>\n\n                      {/* Decor Styling Selection */}\n                      <div>\n                        <label className=\"text-[10px] uppercase tracking-widest text-mauve font-sans font-bold block mb-2\">\n                          3\357\270\217\342\203\243 CORE DECORATION FINISH\n                        </label>\n                        <div className=\"flex flex-wrap gap-2\">\n                          {decorationStyles.map((style) => (\n                            <button\n                              type=\"button\"\n                              key={style}\n                              onClick={() => setCustomDecoration(style)}\n                              className={`px-3 py-2 rounded-lg text-xs tracking-wide transition-all ${\n                                customDecoration === style\n                                  ? \"bg-plum text-cream font-semibold\"\n                                  : \"bg-surface-white hover:bg-plum/5 text-plum border border-plum/10\"\n                              }`}\n                            >\n                              {style}\n                            </button>\n                          ))}\n                        </div>\n                      </div>\n\n                      {/* Personal contact inputs */}\n                      <div className=\"border-t border-plum/10 pt-4 grid grid-cols-1 md:grid-cols-2 gap-4\">\n                        <div>\n                          <label className=\"text-[9px] uppercase tracking-wider text-plum/70 font-sans block mb-1\">\n                            Your full name\n                          </label>\n                          <input\n                            required\n                            type=\"text\"\n                            name=\"fullName\"\n                            placeholder=\"Mahek Baldota\"\n                            className=\"w-full px-3 py-2.5 bg-surface-white border border-plum/15 rounded-lg text-xs text-plum font-sans focus:outline-none focus:border-plum\"\n                          />\n                        </div>\n\n                        <div>\n                          <label className=\"text-[9px] uppercase tracking-wider text-plum/70 font-sans block mb-1\">\n                            Phone index (WhatsApp)\n                          </label>\n                          <input\n                            required\n                            type=\"tel\"\n                            name=\"phone\"\n                            placeholder=\"+91 85000 00000\"\n                            className=\"w-full px-3 py-2.5 bg-surface-white border border-plum/15 rounded-lg text-xs text-plum font-sans focus:outline-none focus:border-plum\"\n                          />\n                        </div>\n                      </div>\n\n                      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                        <div>\n                          <label className=\"text-[9px] uppercase tracking-wider text-plum/70 font-sans block mb-1\">\n                            Pickup Date\n                          </label>\n                          <input\n                            required\n                            type=\"date\"\n                            name=\"pickupDate\"\n                            className=\"w-full px-3 py-2.5 bg-surface-white border border-plum/15 rounded-lg text-xs text-plum font-sans focus:outline-none focus:border-plum\"\n                          />\n                        </div>\n\n                        <div>\n                          <label className=\"text-[9px] uppercase tracking-wider text-plum/70 font-sans block mb-1\">\n                            Flavor customized note (optional)\n                          </label>\n                          <input\n                            type=\"text\"\n                            name=\"designNotes\"\n                            placeholder=\"Add chocolate curls and keep it eggless...\"\n                            className=\"w-full px-3 py-2.5 bg-surface-white border border-plum/15 rounded-lg text-xs text-plum font-sans focus:outline-none focus:border-plum\"\n                          />\n                        </div>\n                      </div>\n\n                      <button\n                        type=\"submit\"\n                        disabled={submittingOrder}\n                        className=\"w-full py-4 mt-6 bg-plum text-cream text-xs font-semibold uppercase tracking-widest rounded-full hover:bg-mauve hover:text-plum transition-colors duration-400 font-sans select-none disabled:bg-plum/50\"\n                      >\n                        {submittingOrder ? \"Registering Gourmet Ticket...\" : \"Submit Order Inquiry\"}\n                      </button>\n                    </form>\n                  )}\n                </div>\n\n              </div>\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>\n\n    </section>\n  );\n}\n\nfunction XButton() {\n  return (\n    <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"w-5 h-5 text-plum\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n      <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n      <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n    </svg>\n  );\n}\n"
    }
