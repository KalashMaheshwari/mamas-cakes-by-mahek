  file_change {
    absolute_path_uri: "file:///src/components/Testimonials.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { useState } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { Star, ChevronLeft, ChevronRight, Quote, Sparkles } from \"lucide-react\";\nimport { Testimonial } from \"../types\";\n\nconst GRADUATE_REVIEWS: Testimonial[] = [\n  {\n    id: \"review-1\",\n    studentName: \"Shruti Mehta\",\n    businessName: \"The Flour Garden, Mumbai\",\n    quote: \"Mahek\'s business blueprint was the absolute turning point for me. I went from selling single-tiered cakes from my home for \342\202\2711,200 to licensing a real boutique kitchen and charging \342\202\27112,000+ for bespoke wedding orders. Her pricing grid represents the holy grail of bakery scaling.\",\n    achievement: \"Scaled to \342\202\2711.5L/month in 8 months\",\n    rating: 5\n  },\n  {\n    id: \"review-2\",\n    studentName: \"Ananya Iyer\",\n    businessName: \"Gilded Whisk Pastry, Chennai\",\n    quote: \"The concrete texturing and palette-knife courses are unbelievably detailed. Most online tutorials just show you the pretty parts; Mahek teaches you the chemical kinetics of making heavy-set buttercream that actually survives 40-degree shipping heat. Absolute game-changer.\",\n    achievement: \"Won local Custom Baker Award\",\n    rating: 5\n  },\n  {\n    id: \"review-3\",\n    studentName: \"Priyanka Patel\",\n    businessName: \"Bakehouse Co., Bangalore\",\n    quote: \"Baking is 50% science and 50% operations. I purchased two other expensive courses, but Mumma\'s Cake is the first that actually teaches contract drafting and booking-fee reservation structures. I am now managing 4 corporate dessert catering contracts!\",\n    achievement: \"Secured high-ticket corporate accounts\",\n    rating: 5\n  },\n  {\n    id: \"review-4\",\n    studentName: \"Kavita Sen\",\n    businessName: \"Rustic Crumb, Delhi\",\n    quote: \"The Artisanal Sourdough & Sponge classes changed everything. Clients constantly tell me my sponge is the most velvety they have ever tasted, moist and spongy without cloying artificial cake syrups or processed emulsifiers. Unbelievably proud to be an alumna.\",\n    achievement: \"48-hour order waitlist achieved\",\n    rating: 5\n  }\n];\n\nexport default function Testimonials() {\n  const [activeIdx, setActiveIdx] = useState(0);\n\n  const handleNext = () => {\n    setActiveIdx((prev) => (prev + 1) % GRADUATE_REVIEWS.length);\n  };\n\n  const handlePrev = () => {\n    setActiveIdx((prev) => (prev - 1 + GRADUATE_REVIEWS.length) % GRADUATE_REVIEWS.length);\n  };\n\n  const activeReview = GRADUATE_REVIEWS[activeIdx];\n\n  return (\n    <section id=\"reviews\" className=\"py-24 md:py-32 bg-cream/50 border-t border-plum/10 relative overflow-hidden\">\n      <div className=\"absolute top-1/2 left-0 w-80 h-80 opacity-20 bg-radial-[circle_at_center] from-mauve/20 via-transparent to-transparent pointer-events-none\" />\n\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12\">\n        \n        {/* Section Header */}\n        <div className=\"text-center max-w-2xl mx-auto mb-16 md:mb-20\">\n          <span className=\"text-xs font-semibold uppercase tracking-[0.25em] text-mauve font-sans block mb-3\">\n            \342\234\246 GRADUATE TRIUMPHS\n          </span>\n          <h2 className=\"font-serif text-4xl sm:text-5xl md:text-6xl font-normal leading-tight text-plum tracking-tight\">\n            Loved by 30,000+ Students\n          </h2>\n          <p className=\"mt-4 text-xs md:text-sm font-semibold uppercase tracking-widest text-mauve font-sans\">\n            MUMMA\'S ALUMAE NETWORK SPANNING 12+ REGIONS\n          </p>\n        </div>\n\n        {/* Testimonials Box Center Stage */}\n        <div className=\"relative max-w-4xl mx-auto\">\n          \n          <AnimatePresence mode=\"wait\">\n            <motion.div\n              key={activeReview.id}\n              initial={{ opacity: 0, x: 20 }}\n              animate={{ opacity: 1, x: 0 }}\n              exit={{ opacity: 0, x: -20 }}\n              transition={{ duration: 0.5, ease: [0.76, 0, 0.24, 1] }}\n              className=\"bg-surface-white border border-plum/10 p-8 md:p-14 rounded-2xl text-left relative flex flex-col md:flex-row gap-10 items-start md:items-center shadow-[0_20px_50px_rgba(21,20,38,0.03)]\"\n            >\n              {/* Huge stylistic quotes mark */}\n              <div className=\"absolute top-6 right-8 text-mauve/15 select-none pointer-events-none hidden md:block\">\n                <Quote className=\"w-24 h-24 stroke-[1.5]\" />\n              </div>\n\n              {/* Text content details */}\n              <div className=\"flex-grow space-y-6\">\n                \n                {/* Score rating star row */}\n                <div className=\"flex items-center gap-1.5\">\n                  {[...Array(5)].map((_, i) => (\n                    <Star key={i} className=\"w-4 h-4 text-plum fill-plum\" />\n                  ))}\n                  <span className=\"text-[10px] font-bold uppercase tracking-widest text-[#D4AF37] font-sans ml-2 flex items-center gap-1\">\n                    <Sparkles className=\"w-3.5 h-3.5\" /> VERIFIED ALUMNA SECURED\n                  </span>\n                </div>\n\n                <blockquote className=\"font-serif text-xl sm:text-2xl md:text-3xl font-light text-plum leading-snug tracking-tight\">\n                  \"{activeReview.quote}\"\n                </blockquote>\n\n                {/* Person identification labels */}\n                <div className=\"pt-6 border-t border-plum/10 flex flex-wrap justify-between items-center gap-4\">\n                  <div>\n                    <h4 className=\"font-serif text-xl text-plum leading-tight\">\n                      {activeReview.studentName}\n                    </h4>\n                    <p className=\"text-xs font-semibold uppercase tracking-wider text-mauve font-sans mt-1\">\n                      {activeReview.businessName}\n                    </p>\n                  </div>\n\n                  <div className=\"px-4 py-2 bg-plum text-cream rounded-full border border-cream/5 select-none text-[10px] uppercase font-bold tracking-widest\">\n                    {activeReview.achievement}\n                  </div>\n                </div>\n\n              </div>\n            </motion.div>\n          </AnimatePresence>\n\n          {/* Nav arrow controls */}\n          <div className=\"flex justify-end gap-3 mt-6\">\n            <button\n              onClick={handlePrev}\n              className=\"p-3 border border-plum/15 hover:border-plum text-plum rounded-full hover:bg-plum hover:text-cream transition-all duration-400 cursor-pointer\"\n              placeholder=\"Previous student review\"\n            >\n              <ChevronLeft className=\"w-5 h-5\" />\n            </button>\n            <button\n              onClick={handleNext}\n              className=\"p-3 border border-plum/15 hover:border-plum text-plum rounded-full hover:bg-plum hover:text-cream transition-all duration-400 cursor-pointer\"\n              placeholder=\"Next student review\"\n            >\n              <ChevronRight className=\"w-5 h-5\" />\n            </button>\n          </div>\n\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
