      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { motion } from \"motion/react\";\nimport { ArrowUpRight, Award, Flame, Star } from \"lucide-react\";\n\ninterface HeroProps {\n  onExploreClick: () => void;\n  onOrderClick: () => void;\n}\n\nexport default function Hero({ onExploreClick, onOrderClick }: HeroProps) {\n  // Editorial transitions easing curve [0.76, 0, 0.24, 1]\n  const transition = { duration: 1.2, ease: [0.76, 0, 0.24, 1] };\n\n  // Define split header lines for staggered reveal\n  const titleLines = [\n    \"Turn Your\",\n    \"Baking Passion\",\n    \"Into a Profitable\",\n    \"Business.\"\n  ];\n\n  return (\n    <section className=\"relative min-h-screen pt-32 md:pt-40 pb-20 px-6 md:px-12 lg:px-24 bg-cream overflow-hidden\">\n      {/* Background Subtle Gradient Glow or Grain Effect */}\n      <div className=\"absolute top-0 right-0 w-1/2 h-full opacity-35 bg-radial-[circle_at_top_right] from-mauve/15 via-transparent to-transparent pointer-events-none\" />\n\n      <div className=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-8 items-center\">\n        \n        {/* Left Editorial Section (55% / columns 1 to 7) */}\n        <div className=\"lg:col-span-7 flex flex-col items-start text-left\">\n          \n          {/* Top Label Tag */}\n          <motion.div\n            initial={{ opacity: 0, y: 15 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ ...transition, delay: 0.1 }}\n            className=\"flex items-center gap-2.5 mb-6\"\n          >\n            <span className=\"w-1.5 h-1.5 bg-plum rounded-full animate-pulse\" />\n            <span className=\"text-xs font-semibold uppercase tracking-[0.25em] text-mauve font-sans\">\n              CULINARY ACADEMY \342\234\246 LUXERY BAKERY\n            </span>\n          </motion.div>\n\n          {/* Staggered Title Reveal Line by Line */}\n          <h1 className=\"font-serif text-5xl sm:text-6xl md:text-7xl xl:text-8xl font-normal leading-[0.9] tracking-tight text-plum block\">\n            {titleLines.map((line, idx) => (\n              <span key={idx} className=\"block overflow-hidden pb-1\" style={{ height: \"auto\" }}>\n                <motion.span\n                  custom={idx}\n                  initial={{ y: \"110%\" }}\n                  animate={{ y: 0 }}\n                  transition={{ ...transition, delay: 0.2 + idx * 0.15 }}\n                  className=\"block origin-left\"\n                >\n                  {line}\n                </motion.span>\n              </span>\n            ))}\n          </h1>\n\n          {/* Business Bio / Pitch */}\n          <motion.p\n            initial={{ opacity: 0, y: 25 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ ...transition, delay: 0.8 }}\n            className=\"mt-8 text-base md:text-lg lg:text-xl font-light leading-relaxed text-plum/85 max-w-[44ch] font-sans\"\n          >\n            Expert-led masterclasses and proven business strategies to start, scale, and succeed in the high-end food industry. Join 30,000+ thriving entrepreneurs.\n          </motion.p>\n\n          {/* Premium Call to Actions */}\n          <motion.div\n            initial={{ opacity: 0, y: 30 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ ...transition, delay: 0.95 }}\n            className=\"mt-10 flex flex-wrap items-center gap-6 md:gap-8\"\n          >\n            {/* Primary Business CTA */}\n            <button\n              onClick={onExploreClick}\n              className=\"group relative flex items-center justify-center gap-2.5 px-8 py-4.5 bg-plum text-cream text-[13px] font-semibold uppercase tracking-widest rounded-full hover:bg-mauve hover:text-plum transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] active:scale-95 shadow-[0_12px_24px_-10px_rgba(33,20,38,0.2)] cursor-pointer overflow-hidden\"\n            >\n              <div className=\"absolute inset-0 w-hidden z-0 bg-mauve/10 scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-550\" />\n              <span className=\"relative z-10\">Explore Masterclasses</span>\n              <ArrowUpRight className=\"relative z-10 w-4 h-4 text-cream group-hover:text-plum group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-300 transform\" />\n            </button>\n\n            {/* Secondary Bakery CTA */}\n            <button\n              onClick={onOrderClick}\n              className=\"group text-sm font-semibold uppercase tracking-widest text-plum hover:text-mauve transition-all py-2 relative cursor-pointer\"\n            >\n              Order Fresh Cakes\n              <span className=\"absolute bottom-0 left-0 w-3/4 h-[1.5px] bg-plum group-hover:w-full transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]\" />\n            </button>\n          </motion.div>\n\n          {/* Fine stats layout row */}\n          <motion.div\n            initial={{ opacity: 0 }}\n            animate={{ opacity: 1 }}\n            transition={{ delay: 1.25, duration: 1 }}\n            className=\"mt-14 md:mt-20 pt-8 border-t border-plum/10 w-full max-w-xl flex gap-10 md:gap-14 text-left\"\n          >\n            <div className=\"flex flex-col gap-1\">\n              <span className=\"font-serif text-3xl text-plum\">30K+</span>\n              <span className=\"text-[10px] uppercase tracking-widest text-mauve font-sans font-medium\">\n                SUCCESSFUL STUDENTS\n              </span>\n            </div>\n            \n            <div className=\"flex flex-col gap-1\">\n              <span className=\"font-serif text-3xl text-plum\">85K+</span>\n              <span className=\"text-[10px] uppercase tracking-widest text-mauve font-sans font-medium\">\n                INSTAGRAM INSPIRED\n              </span>\n            </div>\n\n            <div className=\"flex flex-col gap-1\">\n              <span className=\"font-serif text-3xl text-plum\">100%</span>\n              <span className=\"text-[10px] uppercase tracking-widest text-mauve font-sans font-medium\">\n                VIRAL BUSINESS RECIPES\n              </span>\n            </div>\n          </motion.div>\n\n        </div>\n\n        {/* Right Architectural Image Section (45% / columns 8 to 12) */}\n        <div className=\"lg:col-span-5 relative w-full flex justify-center lg:justify-end\">\n          \n          {/* Background Solid Architectural Frame behind the image container */}\n          <motion.div \n            initial={{ scale: 0.9, opacity: 0 }}\n            animate={{ scale: 1, opacity: 1 }}\n            transition={{ ...transition, delay: 0.4 }}\n            className=\"absolute -inset-1.5 md:-inset-3 border border-plum/5 rounded-t-full rounded-b-xl pointer-events-none\"\n          />\n\n          {/* Architectural Arch container */}\n          <motion.div\n            initial={{ clipPath: \"polygon(0 100%, 100% 100%, 100% 100%, 0 100%)\" }}\n            animate={{ clipPath: \"polygon(0 0, 100% 0, 100% 100%, 0 100%)\" }}\n            transition={{ duration: 1.4, ease: [0.76, 0, 0.24, 1], delay: 0.15 }}\n            className=\"relative w-full max-w-[420px] aspect-[3/4] bg-plum/5 rounded-t-full overflow-hidden\"\n          >\n            \n            {/* Overlay Gradient Filter */}\n            <div className=\"absolute inset-0 bg-gradient-to-t from-plum/30 via-transparent to-transparent z-10 blend-overlay\" />\n\n            {/* Hyper-textured custom image with active keyframe-driven slow zoom */}\n            <motion.img\n              initial={{ scale: 1.15 }}\n              animate={{ scale: 1.0 }}\n              transition={{ duration: 2.2, ease: [0.76, 0, 0.24, 1] }}\n              src=\"https://images.unsplash.com/photo-1606313564200-e75d5e30476c?q=80&w=1200&auto=format&fit=crop\"\n              alt=\"Viral Chocolate Cake Bowl with glossy dark chocolate ganache and beautiful texture\"\n              referrerPolicy=\"no-referrer\"\n              className=\"w-full h-full object-cover origin-center animate-slow-zoom\"\n            />\n\n            {/* floating badge detail or credentials snippet overlay */}\n            <div className=\"absolute bottom-8 right-6 left-6 z-20 bg-cream/90 backdrop-blur-md p-4 rounded-xl border border-plum/10 flex items-center gap-3 shadow-[0_8px_30px_rgb(33,20,38,0.08)]\">\n              <div className=\"p-2 bg-plum text-cream rounded-lg\">\n                <Flame className=\"w-5 h-5 text-cream animate-pulse\" />\n              </div>\n              <div className=\"text-left\">\n                <p className=\"text-[11px] uppercase tracking-widest text-mauve font-sans font-semibold\">\n                  MUMMA\'S SIGNATURE\n                </p>\n                <p className=\"font-serif text-lg leading-tight text-plum mt-0.5\">\n                  Viral Chocolate Fudge Bowl\n                </p>\n              </div>\n            </div>\n\n          </motion.div>\n\n          {/* Floating Luxury Tag on top of the arch */}\n          <motion.div\n            initial={{ opacity: 0, scale: 0.8, rotate: -15 }}\n            animate={{ opacity: 1, scale: 1, rotate: -5 }}\n            transition={{ ...transition, delay: 1.15 }}\n            className=\"absolute -top-6 -left-6 md:-left-10 z-20 bg-plum text-cream p-5 rounded-full flex flex-col items-center justify-center aspect-square shadow-[0_12px_30px_rgba(33,20,38,0.15)] select-none cursor-default group\"\n          >\n            <div className=\"group-hover:rotate-45 transition-transform duration-700 ease-out\">\n              <Star className=\"w-5 h-5 text-cream fill-cream\" />\n            </div>\n            <span className=\"font-serif text-xs italic text-cream mt-1 tracking-tight\">85K+ Strong</span>\n          </motion.div>\n\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
