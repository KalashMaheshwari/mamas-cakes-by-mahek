    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { useState } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { BookOpen, Clock, Users, Star, Sparkles, Check, ArrowRight, X } from \"lucide-react\";\nimport { Course } from \"../types\";\n\nconst ACADEMY_COURSES: Course[] = [\n  {\n    id: \"course-1\",\n    title: \"The Ultimate Cake Business Blueprint\",\n    tag: \"BESTSELLER\",\n    category: \"Business\",\n    description: \"Learn how to turn home-baked masterpieces into a six-figure custom baking business. Includes pricing calculators, client management files, and complete viral branding frameworks.\",\n    price: \"\342\202\2714,999\",\n    duration: \"12 Hours HD On-Demand\",\n    studentsCount: \"14.2K students\",\n    rating: 4.9,\n    image: \"https://images.unsplash.com/photo-1519869325930-281384150729?q=80&w=1200&auto=format&fit=crop\",\n    syllabus: [\n      \"Target Market & Luxury Client Profiling\",\n      \"Dynamic Pricing Formulas & Profit Protection Grid\",\n      \"Social Media Growth: Hooking 100k+ Followers\",\n      \"The Cake Delivery & Damage-Proof Packaging Secrets\"\n    ]\n  },\n  {\n    id: \"course-2\",\n    title: \"Viral Textured Cakes & Modern Frostings\",\n    tag: \"MOST POPULAR\",\n    category: \"Viral Cakes\",\n    description: \"Master Mahek\'s iconic textured design finishes. From rich chocolate fudge layers to concrete, palette-knife floral textures, and velvet sprays.\",\n    price: \"\342\202\2713,999\",\n    duration: \"8 Hours HD On-Demand\",\n    studentsCount: \"9.8K students\",\n    rating: 4.8,\n    image: \"https://images.unsplash.com/photo-1578985545062-69928b1d9587?q=80&w=1200&auto=format&fit=crop\",\n    syllabus: [\n      \"The Master Chocolate Ganache (Perfect Drip & Shape)\",\n      \"Palette Knife Painting with Heavy Buttercream\",\n      \"Sculpting with Wafer Paper, Isomalt & Chocolate Waves\",\n      \"Color Theory & Mixing Custom Pastel Earth Tones\"\n    ]\n  },\n  {\n    id: \"course-3\",\n    title: \"Artisanal Bread & Perfect Vanilla Sponge\",\n    tag: \"ESSENTIAL\",\n    category: \"Baking Essential\",\n    description: \"The science of crumb and texture. Demystify oven spring, hydration ratios, temperature controls, and the ultimate spongy crumb structure.\",\n    price: \"\342\202\2712,499\",\n    duration: \"6 Hours HD On-Demand\",\n    studentsCount: \"4.5K students\",\n    rating: 4.9,\n    image: \"https://images.unsplash.com/photo-1464349172961-10442a8a4718?q=80&w=1200&auto=format&fit=crop\",\n    syllabus: [\n      \"Yeast Science & Lactobacilli Fermentation Cycles\",\n      \"Hydration Mechanics: Handling 80% Wet Dough\",\n      \"Sponge Mechanics: Baking the Airy, Non-Sinking Vanilla Sponge\",\n      \"Steam Injections & Achieving the Dream-like Golden Crust\"\n    ]\n  },\n  {\n    id: \"course-4\",\n    title: \"Elite Wedding Cake Engineering\",\n    tag: \"SIGNATURE\",\n    category: \"Advanced Pastry\",\n    description: \"Learn to build towering, multistoried cakes safely. Learn structural reinforcement, transportation rigs, and pristine fault-line designs.\",\n    price: \"\342\202\2717,999\",\n    duration: \"15 Hours HD On-Demand\",\n    studentsCount: \"2.1K students\",\n    rating: 5.0,\n    image: \"https://images.unsplash.com/photo-1535141192574-5d4897c13636?q=80&w=1200&auto=format&fit=crop\",\n    syllabus: [\n      \"Center doweling & weight distribution calculations\",\n      \"Pristine sharp-edge covering on taller tiers\",\n      \"Designing complex hidden support platforms\",\n      \"The Wedding Day setup: Live-on-site troubleshooting\"\n    ]\n  },\n  {\n    id: \"course-5\",\n    title: \"Gourmet Macarons & French Pastry\",\n    tag: \"PREMIUM ART\",\n    category: \"Advanced Pastry\",\n    description: \"Deconstruct the notoriously finicky French macaron using Italian and French meringue rules. Learn to bake hollow-free, perfectly footed masterpieces.\",\n    price: \"\342\202\2713,499\",\n    duration: \"7.5 Hours HD On-Demand\",\n    studentsCount: \"3.6K students\",\n    rating: 4.7,\n    image: \"https://images.unsplash.com/photo-1569864358642-9d1684040f43?q=80&w=1200&auto=format&fit=crop\",\n    syllabus: [\n      \"Standard Oven Airflow & Hot Spot Calibrations\",\n      \"Macaronage Consistency (Perfect \'Ribbon\' Flow)\",\n      \"Exquisite Ganache Infusions (Lavender, Salted Miso, Pistachio Rose)\",\n      \"High-output mass production for retail bakery display\"\n    ]\n  }\n];\n\nexport default function Courses() {\n  const [selectedCategory, setSelectedCategory] = useState<string>(\"All\");\n  const [activeCourse, setActiveCourse] = useState<Course | null>(null);\n  const [purchaseSuccess, setPurchaseSuccess] = useState(false);\n\n  const categories = [\"All\", \"Business\", \"Viral Cakes\", \"Baking Essential\", \"Advanced Pastry\"];\n\n  const filteredCourses = selectedCategory === \"All\"\n    ? ACADEMY_COURSES\n    : ACADEMY_COURSES.filter(c => c.category === selectedCategory);\n\n  const handleEnroll = () => {\n    setPurchaseSuccess(true);\n    setTimeout(() => {\n      setPurchaseSuccess(false);\n      setActiveCourse(null);\n    }, 4500);\n  };\n\n  return (\n    <section id=\"academy\" className=\"py-24 md:py-32 bg-cream/50 border-t border-plum/10 relative\">\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12\">\n        \n        {/* Section Header */}\n        <div className=\"flex flex-col md:flex-row md:items-end justify-between mb-16 md:mb-20\">\n          <div className=\"text-left max-w-2xl\">\n            <span className=\"text-xs font-semibold uppercase tracking-[0.25em] text-mauve font-sans block mb-3\">\n              \342\234\246 CULINARY ACADEMY\n            </span>\n            <h2 className=\"font-serif text-4xl sm:text-5xl md:text-6xl font-normal leading-tight text-plum tracking-tight\">\n              Master the Craft.<br className=\"hidden sm:block\" /> Master the Business.\n            </h2>\n          </div>\n          <p className=\"mt-6 md:mt-0 text-sm md:text-base font-light text-plum/75 max-w-[35ch] font-sans text-left md:text-right\">\n            Providing 30,000+ chefs, entrepreneurs, and hobbyists with detailed science-based formulas to scale profitable cake businesses.\n          </p>\n        </div>\n\n        {/* Filter Categories Row */}\n        <div className=\"flex flex-wrap items-center gap-3 mb-12 border-b border-plum/10 pb-6\">\n          {categories.map((category) => (\n            <button\n              key={category}\n              onClick={() => setSelectedCategory(category)}\n              className={`px-5 py-2.5 rounded-full text-xs font-semibold uppercase tracking-wider transition-all duration-400 cursor-pointer ${\n                selectedCategory === category\n                  ? \"bg-plum text-cream scale-102\"\n                  : \"bg-transparent text-plum/70 hover:text-plum border border-plum/10 hover:border-plum\"\n              }`}\n            >\n              {category}\n            </button>\n          ))}\n        </div>\n\n        {/* Masterclass Cards Grid */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10\">\n          <AnimatePresence mode=\"popLayout\">\n            {filteredCourses.map((course, idx) => (\n              <motion.div\n                key={course.id}\n                layout\n                initial={{ opacity: 0, y: 30 }}\n                animate={{ opacity: 1, y: 0 }}\n                exit={{ opacity: 0, scale: 0.9 }}\n                transition={{ duration: 0.6, ease: [0.76, 0, 0.24, 1], delay: idx * 0.1 }}\n                className=\"group flex flex-col h-full bg-surface-white border border-plum/10 hover:border-plum transition-all duration-500 overflow-hidden cursor-pointer\"\n                onClick={() => setActiveCourse(course)}\n              >\n                {/* Image Frame */}\n                <div className=\"relative aspect-[4/3] w-full overflow-hidden bg-plum/5\">\n                  <div className=\"absolute inset-0 bg-plum/10 opacity-0 group-hover:opacity-100 transition-opacity z-10 duration-500\" />\n                  \n                  {/* Image tag with referrer policy and smooth transitions */}\n                  <img\n                    src={course.image}\n                    alt={course.title}\n                    referrerPolicy=\"no-referrer\"\n                    className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-[cubic-bezier(0.76,0,0.24,1)]\"\n                  />\n\n                  {/* Horizontal visual indicator bar */}\n                  <div className=\"absolute top-4 left-4 z-20 bg-cream/95 backdrop-blur-sm px-3 py-1 border border-plum/5 rounded-full text-[9px] font-bold uppercase tracking-widest text-plum\">\n                    {course.tag}\n                  </div>\n                </div>\n\n                {/* Content Frame */}\n                <div className=\"p-6 flex flex-col flex-grow text-left\">\n                  <div className=\"flex items-center gap-3 mb-3\">\n                    <span className=\"text-[10px] font-bold uppercase tracking-widest text-mauve\">\n                      {course.category}\n                    </span>\n                    <span className=\"w-1 h-1 bg-mauve/45 rounded-full\" />\n                    <div className=\"flex items-center gap-1 text-[11px] font-semibold text-plum/85 font-sans\">\n                      <Star className=\"w-3 h-3 text-plum fill-plum\" />\n                      <span>{course.rating.toFixed(1)}</span>\n                    </div>\n                  </div>\n\n                  <h3 className=\"font-serif text-2xl font-normal leading-tight text-plum group-hover:text-mauve transition-colors\">\n                    {course.title}\n                  </h3>\n\n                  <p className=\"mt-3 text-sm font-light leading-relaxed text-plum/70 flex-grow font-sans\">\n                    {course.description}\n                  </p>\n\n                  <div className=\"mt-6 pt-5 border-t border-plum/10 flex items-center justify-between\">\n                    <div>\n                      <p className=\"text-[10px] uppercase tracking-widest text-mauve font-sans font-semibold\">\n                        CURRICULUM FEE\n                      </p>\n                      <p className=\"font-serif text-xl font-normal text-plum mt-0.5\">\n                        {course.price}\n                      </p>\n                    </div>\n\n                    <div className=\"flex items-center gap-1.5 text-xs font-semibold uppercase tracking-widest text-plum font-sans border-b border-plum/30 group-hover:border-plum pb-0.5 group-hover:text-mauve transition-all\">\n                      <span>View Curricula</span>\n                      <ArrowRight className=\"w-3.5 h-3.5 group-hover:translate-x-1 transition-transform\" />\n                    </div>\n                  </div>\n                </div>\n              </motion.div>\n            ))}\n          </AnimatePresence>\n        </div>\n\n      </div>\n\n      {/* Slide-out Syllabus Drawer / Modal */}\n      <AnimatePresence>\n        {activeCourse && (\n          <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n            {/* Backdrop Blur overlay */}\n            <motion.div\n              initial={{ opacity: 0 }}\n              animate={{ opacity: 1 }}\n              exit={{ opacity: 0 }}\n              onClick={() => setActiveCourse(null)}\n              className=\"absolute inset-0 bg-plum/75 backdrop-blur-sm\"\n            />\n\n            {/* Content Drawer Box */}\n            <motion.div\n              initial={{ scale: 0.95, opacity: 0, y: 30 }}\n              animate={{ scale: 1, opacity: 1, y: 0 }}\n              exit={{ scale: 0.95, opacity: 0, y: 30 }}\n              transition={{ duration: 0.5, ease: [0.76, 0, 0.24, 1] }}\n              className=\"relative w-full max-w-2xl bg-cream p-8 md:p-10 border border-plum/10 rounded-2xl shadow-[0_32px_64px_rgba(33,20,38,0.25)] z-10 max-h-[90vh] overflow-y-auto\"\n            >\n              <button\n                onClick={() => setActiveCourse(null)}\n                className=\"absolute top-6 right-6 p-2 bg-plum/5 hover:bg-plum/10 text-plum rounded-full transition-colors\"\n                placeholder=\"Close detail drawer\"\n              >\n                <X className=\"w-5 h-5\" />\n              </button>\n\n              {/* Success animation block */}\n              {purchaseSuccess ? (\n                <div className=\"py-16 flex flex-col items-center text-center\">\n                  <motion.div\n                    initial={{ scale: 0.5, opacity: 0 }}\n                    animate={{ scale: 1, opacity: 1 }}\n                    transition={{ type: \"spring\", stiffness: 200, damping: 15 }}\n                    className=\"w-16 h-16 bg-plum text-cream rounded-full flex items-center justify-center mb-6\"\n                  >\n                    <Check className=\"w-8 h-8 text-cream\" />\n                  </motion.div>\n                  <h4 className=\"font-serif text-3xl font-normal text-plum mb-3\">\n                    Registration Confirmed!\n                  </h4>\n                  <p className=\"text-sm font-light text-plum/75 max-w-sm mb-6 font-sans\">\n                    Congratulations! You have taken your first step towards culinary mastery. A personalized onboarding email containing your login, recipe materials, and schedules is on its way.\n                  </p>\n                  <span className=\"text-xs uppercase tracking-widest text-mauve font-semibold font-sans\">\n                    Welcome to Mumma\'s Academy.\n                  </span>\n                </div>\n              ) : (\n                <div className=\"text-left\">\n                  {/* Tags */}\n                  <div className=\"flex items-center gap-3 mb-6\">\n                    <span className=\"px-3 py-1 bg-plum text-cream text-[9px] font-bold uppercase tracking-widest rounded-full\">\n                      {activeCourse.tag}\n                    </span>\n                    <span className=\"text-[10px] font-bold uppercase tracking-widest text-mauve\">\n                      {activeCourse.category}\n                    </span>\n                  </div>\n\n                  {/* Title & Metadata row */}\n                  <h4 className=\"font-serif text-3xl md:text-4xl text-plum mb-4\">\n                    {activeCourse.title}\n                  </h4>\n                  <p className=\"text-sm font-light text-plum/75 mb-6 leading-relaxed font-sans\">\n                    {activeCourse.description}\n                  </p>\n\n                  <div className=\"grid grid-cols-3 gap-4 border-y border-plum/10 py-5 mb-8\">\n                    <div className=\"flex items-center gap-2\">\n                      <Clock className=\"w-4 h-4 text-mauve shrink-0\" />\n                      <div className=\"text-left\">\n                        <p className=\"text-[9px] uppercase tracking-widest text-mauve leading-none font-semibold\">LENGTH</p>\n                        <p className=\"text-xs font-semibold text-plum mt-1\">{activeCourse.duration}</p>\n                      </div>\n                    </div>\n\n                    <div className=\"flex items-center gap-2\">\n                      <Users className=\"w-4 h-4 text-mauve shrink-0\" />\n                      <div className=\"text-left\">\n                        <p className=\"text-[9px] uppercase tracking-widest text-mauve leading-none font-semibold\">GRADUATES</p>\n                        <p className=\"text-xs font-semibold text-plum mt-1\">{activeCourse.studentsCount}</p>\n                      </div>\n                    </div>\n\n                    <div className=\"flex items-center gap-2\">\n                      <BookOpen className=\"w-4 h-4 text-mauve shrink-0\" />\n                      <div className=\"text-left\">\n                        <p className=\"text-[9px] uppercase tracking-widest text-mauve leading-none font-semibold font-sans\">RESOURCES</p>\n                        <p className=\"text-xs font-semibold text-plum mt-1\">PDF Formula Grid</p>\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Syllabus / Curriculum */}\n                  <h5 className=\"font-serif text-lg text-plum mb-4 flex items-center gap-2\">\n                    <Sparkles className=\"w-4 h-4 text-mauve\" />\n                    What you will master\n                  </h5>\n\n                  <ul className=\"space-y-3 mb-8\">\n                    {activeCourse.syllabus.map((item, index) => (\n                      <li key={index} className=\"flex items-start gap-3\">\n                        <div className=\"w-5 h-5 rounded-full bg-mauve/10 flex items-center justify-center shrink-0 mt-0.5\">\n                          <Check className=\"w-3.5 h-3.5 text-plum\" />\n                        </div>\n                        <span className=\"text-[13px] font-light text-plum/85 leading-snug\">{item}</span>\n                      </li>\n                    ))}\n                  </ul>\n\n                  {/* Dynamic checkout total & proceed button */}\n                  <div className=\"flex items-center justify-between pt-6 border-t border-plum/10\">\n                    <div>\n                      <p className=\"text-[10px] uppercase tracking-widest text-mauve font-sans font-semibold\">ALUMNI SPECIAL PRICE</p>\n                      <p className=\"font-serif text-3xl font-normal text-plum mt-0.5\">{activeCourse.price}</p>\n                    </div>\n\n                    <button\n                      onClick={handleEnroll}\n                      className=\"px-8 py-3.5 bg-plum text-cream text-xs font-semibold uppercase tracking-widest rounded-full hover:bg-mauve hover:text-plum transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] active:scale-95 cursor-pointer shadow-[0_12px_24px_rgba(33,20,38,0.15)]\"\n                    >\n                      Enroll in Masterclass\n                    </button>\n                  </div>\n                </div>\n              )}\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>\n\n    </section>\n  );\n}\n"
    }
