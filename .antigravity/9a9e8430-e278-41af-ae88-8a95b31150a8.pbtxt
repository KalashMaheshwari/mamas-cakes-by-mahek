  file_change {
    absolute_path_uri: "file:///src/components/Navigation.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { useState, useEffect } from \"react\";\nimport { Menu, X, ArrowUpRight } from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\ninterface NavigationProps {\n  onOrderClick: () => void;\n  onExploreClick: () => void;\n}\n\nexport default function Navigation({ onOrderClick, onExploreClick }: NavigationProps) {\n  const [isScrolled, setIsScrolled] = useState(false);\n  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);\n\n  useEffect(() => {\n    const handleScroll = () => {\n      if (window.scrollY > 20) {\n        setIsScrolled(true);\n      } else {\n        setIsScrolled(false);\n      }\n    };\n\n    window.addEventListener(\"scroll\", handleScroll);\n    return () => window.removeEventListener(\"scroll\", handleScroll);\n  }, []);\n\n  const scrollToSection = (id: string) => {\n    setIsMobileMenuOpen(false);\n    const element = document.getElementById(id);\n    if (element) {\n      const offset = 80; // height of nav\n      const bodyRect = document.body.getBoundingClientRect().top;\n      const elementRect = element.getBoundingClientRect().top;\n      const elementPosition = elementRect - bodyRect;\n      const offsetPosition = elementPosition - offset;\n\n      window.scrollTo({\n        top: offsetPosition,\n        behavior: \"smooth\"\n      });\n    }\n  };\n\n  return (\n    <>\n      <nav\n        id=\"navbar\"\n        className={`fixed top-0 left-0 w-full z-50 transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] ${\n          isScrolled\n            ? \"py-4 bg-cream/85 backdrop-blur-md border-b border-plum/5 shadow-[0_4px_30px_rgba(33,20,38,0.02)]\"\n            : \"py-6 bg-transparent border-b border-transparent\"\n        }`}\n      >\n        <div className=\"max-w-7xl mx-auto px-6 md:px-12 flex items-center justify-between\">\n          {/* Brand Logo - Elegant Serif */}\n          <button\n            onClick={() => window.scrollTo({ top: 0, behavior: \"smooth\" })}\n            className=\"group text-left\"\n          >\n            <span className=\"font-serif text-2xl md:text-3xl font-normal leading-none tracking-tight text-plum block\">\n              Mumma\'s Cake\n            </span>\n            <span className=\"text-[9px] uppercase tracking-[0.25em] text-mauve block mt-0.5 font-sans\">\n              by Mahek Baldota\n            </span>\n          </button>\n\n          {/* Desktop Links */}\n          <div className=\"hidden lg:flex items-center gap-10 font-sans\">\n            <button\n              onClick={() => scrollToSection(\"academy\")}\n              className=\"text-sm font-medium tracking-wide text-plum/80 hover:text-plum transition-colors relative group py-1\"\n            >\n              The Academy\n              <span className=\"absolute bottom-0 left-0 w-0 h-0.5 bg-plum transition-all duration-300 group-hover:w-full\" />\n            </button>\n            <button\n              onClick={() => scrollToSection(\"bakery\")}\n              className=\"text-sm font-medium tracking-wide text-plum/80 hover:text-plum transition-colors relative group py-1\"\n            >\n              The Bakery\n              <span className=\"absolute bottom-0 left-0 w-0 h-0.5 bg-plum transition-all duration-300 group-hover:w-full\" />\n            </button>\n            <button\n              onClick={() => scrollToSection(\"about-mahek\")}\n              className=\"text-sm font-medium tracking-wide text-plum/80 hover:text-plum transition-colors relative group py-1\"\n            >\n              Mahek\'s Story\n              <span className=\"absolute bottom-0 left-0 w-0 h-0.5 bg-plum transition-all duration-300 group-hover:w-full\" />\n            </button>\n            <button\n              onClick={() => scrollToSection(\"reviews\")}\n              className=\"text-sm font-medium tracking-wide text-plum/80 hover:text-plum transition-colors relative group py-1\"\n            >\n              Student Reviews\n              <span className=\"absolute bottom-0 left-0 w-0 h-0.5 bg-plum transition-all duration-300 group-hover:w-full\" />\n            </button>\n            <button\n              onClick={() => scrollToSection(\"faq\")}\n              className=\"text-sm font-medium tracking-wide text-plum/80 hover:text-plum transition-colors relative group py-1\"\n            >\n              FAQ\n              <span className=\"absolute bottom-0 left-0 w-0 h-0.5 bg-plum transition-all duration-300 group-hover:w-full\" />\n            </button>\n          </div>\n\n          {/* Action Buttons */}\n          <div className=\"hidden lg:flex items-center gap-6\">\n            <button\n              onClick={onOrderClick}\n              className=\"text-sm font-medium text-plum/80 hover:text-plum transition-all flex items-center gap-1 group\"\n            >\n              Order Cakes\n              <ArrowUpRight className=\"w-3.5 h-3.5 text-mauve group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform\" />\n            </button>\n            \n            <button\n              onClick={onExploreClick}\n              className=\"px-6 py-2.5 bg-plum text-cream text-xs font-semibold uppercase tracking-wider rounded-full hover:bg-mauve hover:text-plum transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] active:scale-95 cursor-pointer\"\n            >\n              Start Learning\n            </button>\n          </div>\n\n          {/* Mobile Hamburguer Toggle */}\n          <button\n            onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}\n            className=\"lg:hidden p-2 text-plum hover:text-mauve transition-colors\"\n            placeholder=\"Toggle menu\"\n          >\n            {isMobileMenuOpen ? <X className=\"w-6 h-6\" /> : <Menu className=\"w-6 h-6\" />}\n          </button>\n        </div>\n      </nav>\n\n      {/* Mobile Drawer Menu */}\n      <AnimatePresence>\n        {isMobileMenuOpen && (\n          <motion.div\n            initial={{ opacity: 0, y: -20 }}\n            animate={{ opacity: 1, y: 0 }}\n            exit={{ opacity: 0, y: -20 }}\n            transition={{ duration: 0.4, ease: [0.76, 0, 0.24, 1] }}\n            className=\"fixed top-0 left-0 w-full h-screen bg-cream/98 z-40 pt-28 px-10 flex flex-col justify-between pb-12 lg:hidden border-b border-plum/10\"\n          >\n            <div className=\"flex flex-col gap-6 text-left\">\n              <span className=\"text-xs uppercase tracking-widest text-mauve font-sans block mb-2\">\n                \342\200\224 Menu\n              </span>\n              <button\n                onClick={() => scrollToSection(\"academy\")}\n                className=\"font-serif text-3xl font-light text-plum hover:text-mauve transition-colors py-1 block text-left\"\n              >\n                Culinary Academy\n              </button>\n              <button\n                onClick={() => scrollToSection(\"bakery\")}\n                className=\"font-serif text-3xl font-light text-plum hover:text-mauve transition-colors py-1 block text-left\"\n              >\n                High-End Bakery\n              </button>\n              <button\n                onClick={() => scrollToSection(\"about-mahek\")}\n                className=\"font-serif text-3xl font-light text-plum hover:text-mauve transition-colors py-1 block text-left\"\n              >\n                The Founder\'s Journey\n              </button>\n              <button\n                onClick={() => scrollToSection(\"reviews\")}\n                className=\"font-serif text-3xl font-light text-plum hover:text-mauve transition-colors py-1 block text-left\"\n              >\n                Success Stories\n              </button>\n              <button\n                onClick={() => scrollToSection(\"faq\")}\n                className=\"font-serif text-3xl font-light text-plum hover:text-mauve transition-colors py-1 block text-left\"\n              >\n                Frequently Asked\n              </button>\n            </div>\n\n            <div className=\"flex flex-col gap-4\">\n              <button\n                onClick={() => {\n                  setIsMobileMenuOpen(false);\n                  onOrderClick();\n                }}\n                className=\"w-full py-4 border border-plum/20 hover:border-plum text-plum text-sm font-semibold uppercase tracking-wider rounded-full transition-all text-center block\"\n              >\n                Order Fresh Cakes\n              </button>\n              <button\n                onClick={() => {\n                  setIsMobileMenuOpen(false);\n                  onExploreClick();\n                }}\n                className=\"w-full py-4 bg-plum text-cream text-sm font-semibold uppercase tracking-wider rounded-full hover:bg-mauve transition-all text-center block\"\n              >\n                Explore Masterclasses\n              </button>\n            </div>\n          </motion.div>\n        )}\n      </AnimatePresence>\n    </>\n  );\n}\n"
    }
