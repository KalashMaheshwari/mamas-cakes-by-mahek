  file_change {
    absolute_path_uri: "file:///src/components/ContactFAQ.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { useState } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { ChevronDown, Mail, Phone, MapPin, Send, Check } from \"lucide-react\";\nimport { FAQItem } from \"../types\";\n\nconst ACADEMY_FAQs: FAQItem[] = [\n  {\n    question: \"Are the academy classes live or pre-recorded?\",\n    answer: \"All masterclasses are filmed in exquisite, professional-grade 4K resolution. This means you can study, pause, and master complex palette knife steps at your own pace. You also receive lifetime access to all updates, plus participation privileges in monthly live critique circles hosted by Mahek.\"\n  },\n  {\n    question: \"Do you offer physical kits with the masterclasses?\",\n    answer: \"Yes! Advanced programs like the \'Wedding Cake Engineering\' class include physical ingredient-sourcing directories, structural dowel rigs, and high-quality stainless palette scrapers shipped straight to your doorstep. Standard courses contain fully hyperlinked shopping sheets.\"\n  },\n  {\n    question: \"Are there non-egg or gluten-free options available?\",\n    answer: \"Absolutely. Science is at the heart of Mumma\'s Cake. We include complete eggless, gluten-free, and vegan chemical percentage spreadsheets for all major recipes, engineered carefully to retain pristine sponge structure, crumb elasticity, and moisture content.\"\n  },\n  {\n    question: \"How does local custom cake pick-up operate?\",\n    answer: \"All catalog and custom bakery products require 48 hours notice for baking, stabilizing, and sculpting. Pickups are carefully scheduled from our private pastry workspace in Mumbai. We provide secure carrier platforms to guarantee your cake travels safely.\"\n  }\n];\n\nexport default function ContactFAQ() {\n  const [openFAQIdx, setOpenFAQIdx] = useState<number | null>(0);\n  const [contactSubmitted, setContactSubmitted] = useState(false);\n  const [loading, setLoading] = useState(false);\n\n  const toggleFAQ = (idx: number) => {\n    setOpenFAQIdx(openFAQIdx === idx ? null : idx);\n  };\n\n  const handleContactSubmit = (e: any) => {\n    e.preventDefault();\n    setLoading(true);\n\n    setTimeout(() => {\n      setLoading(false);\n      setContactSubmitted(true);\n    }, 1500);\n  };\n\n  return (\n    <section id=\"faq\" className=\"py-24 md:py-32 bg-cream border-t border-plum/10 relative\">\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-12 items-start\">\n          \n          {/* Left Side: Elegant Accordion FAQs (columns 1 to 6) */}\n          <div className=\"lg:col-span-6 space-y-8 text-left\">\n            <div>\n              <span className=\"text-xs font-semibold uppercase tracking-[0.25em] text-mauve font-sans block mb-3\">\n                \342\234\246 CURATED INQUIRY DESK\n              </span>\n              <h2 className=\"font-serif text-4xl md:text-5xl font-normal leading-tight text-plum tracking-tight\">\n                Frequently Clarified Curricula\n              </h2>\n              <p className=\"mt-4 text-sm font-light text-plum/70 font-sans leading-relaxed\">\n                If you have custom requirements or want to discuss a live corporate baking workshop, don\'t hesitate to check our answers or submit a ticket directly.\n              </p>\n            </div>\n\n            <div className=\"space-y-4\">\n              {ACADEMY_FAQs.map((faq, idx) => {\n                const isOpen = openFAQIdx === idx;\n                return (\n                  <div\n                    key={idx}\n                    className=\"border-b border-plum/15 pb-4 last:border-none transition-colors\"\n                  >\n                    <button\n                      onClick={() => toggleFAQ(idx)}\n                      className=\"w-full flex items-center justify-between text-left py-4 focus:outline-none group cursor-pointer\"\n                    >\n                      <h3 className=\"font-serif text-xl text-plum group-hover:text-mauve transition-colors\">\n                        {faq.question}\n                      </h3>\n                      <ChevronDown\n                        className={`w-5 h-5 text-mauve transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] ${\n                          isOpen ? \"rotate-180 text-plum\" : \"rotate-0\"\n                        }`}\n                      />\n                    </button>\n\n                    <AnimatePresence initial={false}>\n                      {isOpen && (\n                        <motion.div\n                          initial={{ height: 0, opacity: 0 }}\n                          animate={{ height: \"auto\", opacity: 1 }}\n                          exit={{ height: 0, opacity: 0 }}\n                          transition={{ duration: 0.4, ease: [0.76, 0, 0.24, 1] }}\n                          className=\"overflow-hidden\"\n                        >\n                          <p className=\"text-sm font-light text-plum/75 font-sans leading-relaxed pt-2 pb-4\">\n                            {faq.answer}\n                          </p>\n                        </motion.div>\n                      )}\n                    </AnimatePresence>\n                  </div>\n                );\n              })}\n            </div>\n            \n            {/* Quick contact direct channels */}\n            <div className=\"pt-8 grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-plum/10 font-sans text-xs\">\n              <div className=\"flex gap-3 items-center\">\n                <div className=\"p-2.5 bg-plum/5 rounded-full text-plum\">\n                  <Mail className=\"w-4 h-4\" />\n                </div>\n                <div className=\"text-left font-sans\">\n                  <p className=\"text-[10px] uppercase font-bold text-mauve\">ACADEMY DIRECT</p>\n                  <p className=\"font-medium text-plum mt-0.5\">academy@mummascake.com</p>\n                </div>\n              </div>\n\n              <div className=\"flex gap-3 items-center\">\n                <div className=\"p-2.5 bg-plum/5 rounded-full text-plum\">\n                  <Phone className=\"w-4 h-4\" />\n                </div>\n                <div className=\"text-left font-sans\">\n                  <p className=\"text-[10px] uppercase font-bold text-mauve\">BAKERY INTAKE</p>\n                  <p className=\"font-medium text-plum mt-0.5\">+91 85981-98765</p>\n                </div>\n              </div>\n            </div>\n\n          </div>\n\n          {/* Right Side: Contact & Custom Request form (columns 7 to 12) */}\n          <div className=\"lg:col-span-6 bg-surface-white border border-plum/10 p-8 md:p-10 rounded-2xl shadow-[0_20px_50px_rgba(21,20,38,0.03)] text-left\">\n            {contactSubmitted ? (\n              <motion.div\n                initial={{ opacity: 0, scale: 0.95 }}\n                animate={{ opacity: 1, scale: 1 }}\n                className=\"py-12 text-center flex flex-col items-center\"\n              >\n                <div className=\"w-14 h-14 bg-plum text-cream rounded-full flex items-center justify-center mb-6\">\n                  <Check className=\"w-7 h-7 text-cream\" />\n                </div>\n                <h3 className=\"font-serif text-3xl text-plum mb-3\">\n                  Inquiry Dispatched!\n                </h3>\n                <p className=\"text-sm font-light text-plum/75 font-sans max-w-sm\">\n                  We have logged your custom masterclass request or bakery inquiry. Mahek Baldota\'s team will analyze the details and reach back with beautiful blueprints and quote tables within 24 hours.\n                </p>\n                <button\n                  onClick={() => setContactSubmitted(false)}\n                  className=\"mt-8 px-6 py-3 bg-plum text-cream text-[10px] font-bold uppercase tracking-widest rounded-full hover:bg-mauve\"\n                >\n                  Submit Another Ticket\n                </button>\n              </motion.div>\n            ) : (\n              <form onSubmit={handleContactSubmit} className=\"space-y-6\">\n                <div>\n                  <h3 className=\"font-serif text-2xl text-plum mb-1\">\n                    Begin Your Culinary Inquiry\n                  </h3>\n                  <p className=\"text-xs font-light text-plum/70 font-sans leading-relaxed\">\n                    Have bespoke brand training programs or custom cake ideas? Let\'s discuss directly.\n                  </p>\n                </div>\n\n                <div className=\"space-y-4\">\n                  <div>\n                    <label className=\"text-[9px] uppercase tracking-wider text-plum/75 font-bold font-sans block mb-1\">\n                      Your Full Name\n                    </label>\n                    <input\n                      required\n                      type=\"text\"\n                      name=\"userName\"\n                      placeholder=\"Mahek Baldota\"\n                      className=\"w-full px-4 py-3 bg-cream border border-plum/10 rounded-lg text-sm text-plum focus:outline-none focus:border-plum\"\n                    />\n                  </div>\n\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                    <div>\n                      <label className=\"text-[9px] uppercase tracking-wider text-plum/75 font-bold font-sans block mb-1\">\n                        Email Address\n                      </label>\n                      <input\n                        required\n                        type=\"email\"\n                        name=\"userEmail\"\n                        placeholder=\"chef@gmail.com\"\n                        className=\"w-full px-4 py-3 bg-cream border border-plum/10 rounded-lg text-sm text-plum focus:outline-none focus:border-plum\"\n                      />\n                    </div>\n\n                    <div>\n                      <label className=\"text-[9px] uppercase tracking-wider text-plum/75 font-bold font-sans block mb-1\">\n                        What matches your dream?\n                      </label>\n                      <select\n                        name=\"intent\"\n                        className=\"w-full px-4 py-3 bg-cream border border-plum/10 rounded-lg text-sm text-plum focus:outline-none focus:border-plum\"\n                      >\n                        <option>Academy Enrollment Queries</option>\n                        <option>Bespoke Creative Cake Orders</option>\n                        <option>Corporate Pastry Consulting</option>\n                        <option>Media & Brand Partnering</option>\n                      </select>\n                    </div>\n                  </div>\n\n                  <div>\n                    <label className=\"text-[9px] uppercase tracking-wider text-plum/75 font-bold font-sans block mb-1\">\n                      Inquiry Notes\n                    </label>\n                    <textarea\n                      required\n                      rows={4}\n                      name=\"userMsg\"\n                      placeholder=\"Discussing customized structures, scale details, or scheduling live workshops...\"\n                      className=\"w-full px-4 py-3 bg-cream border border-plum/10 rounded-lg text-sm text-plum focus:outline-none focus:border-plum leading-relaxed\"\n                    />\n                  </div>\n                </div>\n\n                <button\n                  type=\"submit\"\n                  disabled={loading}\n                  className=\"w-full py-4 bg-plum text-cream text-[11px] font-bold uppercase tracking-widest rounded-full hover:bg-mauve hover:text-plum transition-all duration-500 flex items-center justify-center gap-2 cursor-pointer disabled:bg-plum/50\"\n                >\n                  {loading ? (\n                    <span>Dispatching Ticket...</span>\n                  ) : (\n                    <>\n                      <span>Send Message to Mahek</span>\n                      <Send className=\"w-3.5 h-3.5\" />\n                    </>\n                  )}\n                </button>\n              </form>\n            )}\n          </div>\n\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    }
