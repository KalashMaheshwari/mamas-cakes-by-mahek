  file_change {
    absolute_path_uri: "file:///src/components/CakeArtistryLab.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { useState } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { Sparkles, TrendingUp, Info, Activity, Flame, ShieldAlert, CheckCircle2, ChevronRight, DollarSign } from \"lucide-react\";\n\ninterface CakeSpecimen {\n  id: string;\n  name: string;\n  category: string;\n  image: string;\n  textureRating: string;\n  viralMetric: string;\n  chemistrySecret: string;\n}\n\nconst VIRAL_SPECIMENS: CakeSpecimen[] = [\n  {\n    id: \"specimen-1\",\n    name: \"Impasto Palette-Knife Bloom\",\n    category: \"Heavy Buttercream\",\n    image: \"https://images.unsplash.com/photo-1535141192574-5d4897c13636?q=80&w=800&auto=format&fit=crop\",\n    textureRating: \"Dense Crisp Petals\",\n    viralMetric: \"4.2M Reels Views\",\n    chemistrySecret: \"Emulsifying organic cold butter with a stabilizer at precisely 21.5\302\260C to avoid atmospheric melting.\"\n  },\n  {\n    id: \"specimen-2\",\n    name: \"Architectural Vault Gilded Concrete\",\n    category: \"Ganache Sculpture\",\n    image: \"https://images.unsplash.com/photo-1542826438-bd32f43d626f?q=80&w=800&auto=format&fit=crop\",\n    textureRating: \"Slate-like Metallic Crust\",\n    viralMetric: \"2.8M Reels Views\",\n    chemistrySecret: \"A triple-tempered Belgian dark chocolate shield whipped at 85% hydration for seamless structural strength.\"\n  },\n  {\n    id: \"specimen-3\",\n    name: \"Pistachio Raspberry Velvet Spray\",\n    category: \"Cocoa Matte Finishes\",\n    image: \"https://images.unsplash.com/photo-1578985545062-69928b1d9587?q=80&w=800&auto=format&fit=crop\",\n    textureRating: \"Fuzzy Micro-Textured Shell\",\n    viralMetric: \"1.9M Reels Views\",\n    chemistrySecret: \"Airbrushing a 50:50 ratio of premium white cocoa butter and organic food dyes on frozen sponge cores.\"\n  }\n];\n\ninterface CrumbState {\n  label: string;\n  description: string;\n  causes: string[];\n  scientificFix: string;\n  airBubbleDensity: \"dense\" | \"perfect\" | \"unstable\";\n}\n\nconst CRUMB_LAB: Record<string, CrumbState> = {\n  collapsed: {\n    label: \"The Sunk & Wet Center\",\n    description: \"The classic tragedy of an under-baked or over-leavened core that sinks upon exposure to room-temperature drafts, creating a rubbery, gummy bottom line.\",\n    causes: [\n      \"Too much chemical leavener creating unstable gas networks\",\n      \"Oven door opened before the sponge gluten matrix fully coagulated\",\n      \"Sugar ratio exceeding 130% of flour weight\"\n    ],\n    scientificFix: \"Reduce chemical aeration by 15%, use precise weights rather than volume spoons, and bake under static non-convection airflow.\",\n    airBubbleDensity: \"dense\"\n  },\n  dry: {\n    label: \"The Coarse, Brittle Crumb\",\n    description: \"A cake that turns into chalky crumbs upon slicing, making it impossible to apply clean palette-knife tension without tear-outs.\",\n    causes: [\n      \"Over-whipping eggs causing massive, brittle air pockets\",\n      \"Flour structure dryout from low fat-binding ratios\",\n      \"Over-baking by even 4 minutes beyond the coagulation peak\"\n    ],\n    scientificFix: \"Fold in 5% organic sour cream to bind moisture, and transition egg whipping to a slow, dense ribbon-stage maximum.\",\n    airBubbleDensity: \"unstable\"\n  },\n  perfect: {\n    label: \"Mumma\'s Signature Cushioned Crumb\",\n    description: \"The gold standard of baking. An airy, incredibly moist, feather-light velvet crumb with infinite sponge elasticity. Carries 3kg of custom sculptural weight with absolute structural integrity.\",\n    causes: [\n      \"Perfect starch gelation at exactly 92\302\260C core temperature\",\n      \"Controlled gluten length through double-sifted soft protein flour\",\n      \"Emulsified fat suspension that traps tiny uniform air bubbles\"\n    ],\n    scientificFix: \"Sift flour three times to trap electrostatic air, hydrate the sponge at exactly 78% ratio, and rest the batter for 12 minutes before oven entry.\",\n    airBubbleDensity: \"perfect\"\n  }\n};\n\nexport default function CakeArtistryLab() {\n  const [activeSpecimen, setActiveSpecimen] = useState<string>(\"specimen-1\");\n  const [crumbQuery, setCrumbQuery] = useState<string>(\"perfect\");\n  \n  // Interactive Business Estimator States\n  const [weeklyCakes, setWeeklyCakes] = useState<number>(5);\n  const [cakePrice, setCakePrice] = useState<number>(3500);\n  const [ingredientCost, setIngredientCost] = useState<number>(800);\n\n  const calculatedRevenue = weeklyCakes * cakePrice;\n  const calculatedCost = weeklyCakes * ingredientCost;\n  const calculatedProfit = calculatedRevenue - calculatedCost;\n\n  return (\n    <section id=\"artistry-lab\" className=\"py-24 md:py-32 bg-cream relative overflow-hidden\">\n      {/* Decorative Radial Poppy highlights for a vibrant editorial look */}\n      <div className=\"absolute top-0 left-1/4 w-[500px] h-[500px] bg-[#FFF2CD] rounded-full filter blur-[100px] opacity-40 pointer-events-none\" />\n      <div className=\"absolute bottom-1/4 right-0 w-[400px] h-[400px] bg-mauve/15 rounded-full filter blur-[120px] opacity-35 pointer-events-none\" />\n\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12\">\n        \n        {/* Editorial Section Header */}\n        <div className=\"max-w-3xl text-left mb-16 md:mb-24\">\n          <span className=\"text-xs font-semibold uppercase tracking-[0.3em] text-[#80173F] bg-[#80173F]/5 px-3 py-1.5 rounded-full font-sans inline-block mb-4\">\n            \342\234\246 HIGH-TEXTURE PROOF-OF-WORK\n          </span>\n          <h2 className=\"font-serif text-5xl sm:text-6xl md:text-7xl font-normal leading-tight text-plum tracking-tight\">\n            We Don\'t Just Teach.<br />\n            We Sculpt Masterpieces.\n          </h2>\n          <p className=\"mt-6 text-base md:text-lg font-light text-plum/80 font-sans leading-relaxed max-w-2xl\">\n            Mahek Baldota built her 85K+ follower empire on one core principle: <strong className=\"text-[#80173F]\">extreme culinary texture</strong>. Below, explore the real physics, science, and viral statistics behind our custom works that fuel our academy curriculums.\n          </p>\n        </div>\n\n        {/* 1. Interactive Splendid Gallery showcasing hyper-textured cakes */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center mb-32\">\n          \n          {/* Left Block: The Image Showcase */}\n          <div className=\"lg:col-span-7 relative\">\n            <div className=\"absolute -inset-2 border border-plum/10 rounded-2xl pointer-events-none z-10\" />\n            <div className=\"aspect-[4/3] w-full bg-plum/5 rounded-xl overflow-hidden shadow-[0_30px_60px_-15px_rgba(33,20,38,0.1)] relative\">\n              <AnimatePresence mode=\"wait\">\n                {VIRAL_SPECIMENS.map((spec) => {\n                  if (spec.id !== activeSpecimen) return null;\n                  return (\n                    <motion.img\n                      key={spec.id}\n                      initial={{ scale: 1.1, opacity: 0 }}\n                      animate={{ scale: 1, opacity: 1 }}\n                      exit={{ scale: 1.05, opacity: 0 }}\n                      transition={{ duration: 0.8, ease: [0.76, 0, 0.24, 1] }}\n                      src={spec.image}\n                      alt={spec.name}\n                      referrerPolicy=\"no-referrer\"\n                      className=\"absolute inset-0 w-full h-full object-cover\"\n                    />\n                  );\n                })}\n              </AnimatePresence>\n              \n              {/* Overlay stats card */}\n              <div className=\"absolute bottom-6 left-6 z-20 bg-cream/95 backdrop-blur-md px-5 py-4 rounded-xl border border-plum/10 flex items-center gap-4\">\n                <div>\n                  <p className=\"text-[10px] font-sans font-bold uppercase tracking-widest text-[#80173F]\">VIRAL POWER</p>\n                  <p className=\"font-serif text-xl font-normal text-plum mt-1\">\n                    {VIRAL_SPECIMENS.find(s => s.id === activeSpecimen)?.viralMetric}\n                  </p>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          {/* Right Block: Interactive Selector & The Scientific explanation */}\n          <div className=\"lg:col-span-5 flex flex-col justify-center text-left\">\n            <span className=\"text-[10px] font-bold uppercase tracking-[0.2em] text-mauve font-sans block mb-3\">\342\200\224 THE EXHIBITS</span>\n            <div className=\"space-y-4\">\n              {VIRAL_SPECIMENS.map((spec) => {\n                const isActive = spec.id === activeSpecimen;\n                return (\n                  <button\n                    key={spec.id}\n                    onClick={() => setActiveSpecimen(spec.id)}\n                    className={`w-full p-5 rounded-xl border text-left transition-all duration-400 cursor-pointer ${\n                      isActive\n                        ? \"bg-surface-white border-[#80173F] shadow-[0_15px_30px_-10px_rgba(128,23,63,0.08)] scale-[1.02]\"\n                        : \"bg-transparent border-plum/12 hover:border-plum\"\n                    }`}\n                  >\n                    <div className=\"flex justify-between items-start\">\n                      <div>\n                        <h4 className=\"font-serif text-xl text-plum leading-tight\">{spec.name}</h4>\n                        <p className=\"text-xs text-mauve font-sans mt-1\">{spec.category}</p>\n                      </div>\n                      <span className=\"text-[11px] font-mono bg-plum/5 text-plum px-2.5 py-1 rounded-full uppercase\">\n                        {spec.textureRating}\n                      </span>\n                    </div>\n\n                    {isActive && (\n                      <motion.div\n                        initial={{ opacity: 0, height: 0 }}\n                        animate={{ opacity: 1, height: \"auto\" }}\n                        transition={{ duration: 0.3 }}\n                        className=\"mt-4 pt-4 border-t border-plum/10\"\n                      >\n                        <p className=\"text-xs font-semibold uppercase tracking-wider text-[#80173F] font-sans flex items-center gap-1.5\">\n                          <Activity className=\"w-3.5 h-3.5\" />\n                          The Chemical Catalyst Secret:\n                        </p>\n                        <p className=\"text-xs font-light text-plum/80 leading-relaxed mt-1.5 font-sans\">\n                          {spec.chemistrySecret}\n                        </p>\n                      </motion.div>\n                    )}\n                  </button>\n                );\n              })}\n            </div>\n          </div>\n\n        </div>\n\n        {/* 2. THE SCIENTIFIC CRUMB ANALYZER (Unique Interactive Tool) */}\n        <div className=\"bg-[#FFFEEF] border border-plum/10 rounded-2xl p-8 md:p-14 mb-32 relative text-left\">\n          <div className=\"absolute top-6 right-6 text-mauve/20 select-none hidden md:block\">\n            <Flame className=\"w-20 h-20 animate-pulse\" />\n          </div>\n\n          <div className=\"max-w-2xl\">\n            <span className=\"text-[10px] font-bold uppercase tracking-[0.25em] text-[#80173F] bg-[#80173F]/5 px-3 py-1 font-sans rounded-full\">\n              INTERACTIVE MICROSCOPIC SIMULATION\n            </span>\n            <h3 className=\"font-serif text-3xl sm:text-4xl text-plum mt-4 tracking-tight\">\n              The Molecular Pastry Lab\n            </h3>\n            <p className=\"text-sm font-light text-plum/80 font-sans mt-2 leading-relaxed\">\n              Tension, hydration, and oven-spring isn\'t guessing work. Click on each crumb profile below to analyze crumb cross-sections and view cellular repairs before buying.\n            </p>\n          </div>\n\n          {/* Selector Row */}\n          <div className=\"flex flex-wrap gap-3 mt-8 border-b border-plum/10 pb-6\">\n            {Object.keys(CRUMB_LAB).map((key) => (\n              <button\n                key={key}\n                onClick={() => setCrumbQuery(key)}\n                className={`px-5 py-3 rounded-lg text-xs font-semibold uppercase tracking-wider cursor-pointer transition-all duration-300 ${\n                  crumbQuery === key\n                    ? \"bg-[#80173F] text-cream scale-102\"\n                    : \"bg-surface-white hover:bg-plum/5 text-plum border border-plum/10\"\n                }`}\n              >\n                {CRUMB_LAB[key].label}\n              </button>\n            ))}\n          </div>\n\n          {/* Simulated view grid */}\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 mt-8 items-center\">\n            \n            {/* Visual simulation bubble board */}\n            <div className=\"lg:col-span-4 bg-cream border border-plum/12 rounded-xl p-6 min-h-[190px] flex flex-col justify-center items-center relative overflow-hidden shadow-inner\">\n              <p className=\"text-[9px] uppercase tracking-wider text-mauve font-sans font-bold absolute top-3 left-4\">\n                CELLULAR SIMULATION\n              </p>\n              \n              {/* Bubble representations */}\n              <div className=\"flex flex-wrap justify-center gap-1.5 max-w-[180px]\">\n                {crumbQuery === \"perfect\" && (\n                  [...Array(40)].map((_, i) => (\n                    <motion.div\n                      key={i}\n                      animate={{ scale: [1, 1.1, 1] }}\n                      transition={{ duration: 2 + (i % 3), repeat: Infinity }}\n                      className=\"w-3.5 h-3.5 rounded-full bg-[#80173F]/20 border border-[#80173F]/10 flex items-center justify-center text-[5px]\"\n                    />\n                  ))\n                )}\n                {crumbQuery === \"collapsed\" && (\n                  [...Array(24)].map((_, i) => (\n                    <div\n                      key={i}\n                      className=\"w-2 h-7 rounded-sm bg-[#5E2B3E]/35 border border-[#5E2B3E]/10\"\n                    />\n                  ))\n                )}\n                {crumbQuery === \"dry\" && (\n                  [...Array(15)].map((_, i) => (\n                    <div\n                      key={i}\n                      className=\"w-9 h-9 rounded-full bg-transparent border-2 border-[#DCAE1D]/50 flex items-center justify-center\"\n                    />\n                  ))\n                )}\n              </div>\n              <p className=\"text-[10px] font-mono text-plum/60 mt-4\">\n                {crumbQuery === \"perfect\" ? \"Uniform Elastic Pockets\" : crumbQuery === \"collapsed\" ? \"Dense Flattened Gluten Sheets\" : \"Over-blown Coarse Gas Pockets\"}\n              </p>\n            </div>\n\n            {/* Scientific Explanation Column */}\n            <div className=\"lg:col-span-8 space-y-4\">\n              <h4 className=\"font-serif text-2xl text-plum leading-none\">\n                {CRUMB_LAB[crumbQuery].label} Analysis\n              </h4>\n              <p className=\"text-xs md:text-sm font-light text-plum/80 leading-relaxed font-sans\">\n                {CRUMB_LAB[crumbQuery].description}\n              </p>\n              \n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 pt-4 border-t border-plum/10\">\n                <div>\n                  <p className=\"text-[9px] uppercase tracking-wider text-[#A22026] font-bold flex items-center gap-1\">\n                    <ShieldAlert className=\"w-3.5 h-3.5\" /> Core Culinary Failures\n                  </p>\n                  <ul className=\"text-xs font-light text-plum/75 space-y-1.5 mt-2 list-disc pl-4 font-sans\">\n                    {CRUMB_LAB[crumbQuery].causes.map((ca, idx) => (\n                      <li key={idx}>{ca}</li>\n                    ))}\n                  </ul>\n                </div>\n\n                <div className=\"bg-[#FFFCE8] p-4 rounded-lg border border-plum/5\">\n                  <p className=\"text-[9px] uppercase tracking-wider text-[#80173F] font-bold flex items-center gap-1 font-sans\">\n                    <CheckCircle2 className=\"w-3.5 h-3.5\" /> The Academy Scientific Fix\n                  </p>\n                  <p className=\"text-xs font-medium text-[#80173F] mt-2 leading-relaxed font-sans\">\n                    {CRUMB_LAB[crumbQuery].scientificFix}\n                  </p>\n                </div>\n              </div>\n            </div>\n\n          </div>\n        </div>\n\n        {/* 3. CORE VALUE CALCULATOR: THE CAKE BUSINESS PROFIT RETOUR */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center bg-plum text-cream rounded-3xl p-8 md:p-16 relative shadow-[0_30px_70px_rgba(33,20,38,0.25)] text-left\">\n          \n          {/* Left instructions block */}\n          <div className=\"lg:col-span-5 flex flex-col justify-center\">\n            <span className=\"text-[10px] uppercase font-bold tracking-widest text-[#DCAE1D] font-sans block mb-4\">\n              \342\234\246 ACADEMY VALUATION TOOL\n            </span>\n            <h3 className=\"font-serif text-3xl sm:text-4xl text-cream tracking-tight leading-tight\">\n              Calculate Your Custom Baking Profits\n            </h3>\n            <p className=\"text-xs md:text-sm font-light text-cream/70 font-sans mt-3 leading-relaxed\">\n              A single-tiered home cake made with generic supermarket mixes will rarely yield more than \342\202\2711,200. Contrast that with highly-branded, gorgeous textured sculptures that command \342\202\2714,000 to \342\202\27112,000. Slide the parameters to see the power of branding we teach.\n            </p>\n\n            <div className=\"mt-8 space-y-4 font-sans text-xs\">\n              <div className=\"flex gap-3 items-center\">\n                <CheckCircle2 className=\"w-5 h-5 text-[#DCAE1D]\" />\n                <span>Price anchoring strategies to reject low budget buyers</span>\n              </div>\n              <div className=\"flex gap-3 items-center\">\n                <CheckCircle2 className=\"w-5 h-5 text-[#DCAE1D]\" />\n                <span>Ingredient margin balancing and material leverage scripts</span>\n              </div>\n              <div className=\"flex gap-3 items-center\">\n                <CheckCircle2 className=\"w-5 h-5 text-[#DCAE1D]\" />\n                <span>Corporate retainer booking strategies</span>\n              </div>\n            </div>\n          </div>\n\n          {/* Right Interface Slider box */}\n          <div className=\"lg:col-span-7 bg-cream/5 border border-cream/10 rounded-2xl p-6 md:p-10 flex flex-col gap-8\">\n            <p className=\"text-xs font-mono text-[#DCAE1D] uppercase leading-none border-b border-cream/10 pb-3\">\n              LIVE LEDGER ESTIMATOR\n            </p>\n\n            {/* Slider 1: Cakes Sold */}\n            <div>\n              <div className=\"flex justify-between font-sans text-xs font-medium mb-2 text-cream/90\">\n                <span>1\357\270\217\342\203\243 Custom Cakes Baked per Week</span>\n                <span className=\"text-[#DCAE1D] font-bold text-sm\">{weeklyCakes} cakes</span>\n              </div>\n              <input\n                type=\"range\"\n                min=\"2\"\n                max=\"25\"\n                step=\"1\"\n                value={weeklyCakes}\n                onChange={(e) => setWeeklyCakes(parseInt(e.target.value, 10))}\n                className=\"w-full accent-[#80173F] cursor-pointer bg-cream/10 rounded-lg appearance-none h-1.5\"\n              />\n            </div>\n\n            {/* Slider 2: Retail price per Cake */}\n            <div>\n              <div className=\"flex justify-between font-sans text-xs font-medium mb-2 text-cream/90\">\n                <span>2\357\270\217\342\203\243 Commission Price per Cake (Bespoke Artwork)</span>\n                <span className=\"text-[#DCAE1D] font-bold text-sm\">\342\202\271{cakePrice.toLocaleString()}</span>\n              </div>\n              <input\n                type=\"range\"\n                min=\"1200\"\n                max=\"15000\"\n                step=\"200\"\n                value={cakePrice}\n                onChange={(e) => setCakePrice(parseInt(e.target.value, 10))}\n                className=\"w-full accent-[#80173F] cursor-pointer bg-cream/10 rounded-lg appearance-none h-1.5\"\n              />\n            </div>\n\n            {/* Slider 3: Material Cost */}\n            <div>\n              <div className=\"flex justify-between font-sans text-xs font-medium mb-2 text-cream/90\">\n                <span>3\357\270\217\342\203\243 Ingredient Cost per Cake (Premium Materials)</span>\n                <span className=\"text-[#DCAE1D] font-bold text-sm\">\342\202\271{ingredientCost.toLocaleString()}</span>\n              </div>\n              <input\n                type=\"range\"\n                min=\"300\"\n                max=\"3000\"\n                step=\"100\"\n                value={ingredientCost}\n                onChange={(e) => setIngredientCost(parseInt(e.target.value, 10))}\n                className=\"w-full accent-[#80173F] cursor-pointer bg-cream/10 rounded-lg appearance-none h-1.5\"\n              />\n            </div>\n\n            {/* Calculated Profits Box */}\n            <div className=\"grid grid-cols-2 gap-4 pt-6 border-t border-cream/10\">\n              <div>\n                <p className=\"text-[10px] font-sans font-semibold uppercase tracking-widest text-cream/55\">ESTIMATED REVENUE</p>\n                <p className=\"font-serif text-2xl md:text-3xl text-cream mt-1\">\342\202\271{calculatedRevenue.toLocaleString()}</p>\n              </div>\n\n              <div>\n                <p className=\"text-[10px] font-sans font-semibold uppercase tracking-widest text-[#DCAE1D]\">NET SAVED PROFIT / MO</p>\n                <p className=\"font-serif text-2xl md:text-3xl text-[#DCAE1D] mt-1\">\342\202\271{(calculatedProfit * 4.2).toLocaleString()}</p>\n              </div>\n            </div>\n\n            <div className=\"bg-[#80173F]/20 p-4 border border-[#80173F]/20 rounded-xl leading-relaxed text-left\">\n              <p className=\"text-xs font-light text-cream/90 flex gap-1.5 items-start\">\n                <TrendingUp className=\"w-5 h-5 text-[#DCAE1D] shrink-0 mt-0.5\" />\n                <span>\n                  By shifting your brand perception from a generic custom home baker to a <strong>luxury dessert architect</strong> using our business blueprints, you increase your pricing ceiling by average <strong>280% on the same labor budget</strong>.\n                </span>\n              </p>\n            </div>\n          </div>\n\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
