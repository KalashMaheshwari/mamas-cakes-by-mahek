      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { motion } from \"motion/react\";\nimport { ArrowUpRight, Award, Flame, Star, Instagram } from \"lucide-react\";\n\nexport default function AboutMahek() {\n  const transition = { duration: 1, ease: [0.76, 0, 0.24, 1] };\n\n  return (\n    <section id=\"about-mahek\" className=\"py-24 md:py-32 bg-cream/30 border-t border-plum/10 relative overflow-hidden\">\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-12 items-center\">\n          \n          {/* Left Column: Architectural Portrait Frame */}\n          <div className=\"lg:col-span-5 relative w-full flex justify-center lg:justify-start order-2 lg:order-1\">\n            <div className=\"relative w-full max-w-[380px] aspect-[4/5] bg-plum/5 rounded-t-[10rem] rounded-b-2xl overflow-hidden shadow-[0_20px_50px_rgba(21,20,38,0.06)] border border-plum/10\">\n              \n              {/* Photo placeholder representing Mahek Baldota */}\n              <img\n                src=\"https://images.unsplash.com/photo-1595273670150-db0a3e368157?q=80&w=800&auto=format&fit=crop\"\n                alt=\"Mahek Baldota, founder of Mumma\'s Cake in culinary apron coaching students\"\n                referrerPolicy=\"no-referrer\"\n                className=\"w-full h-full object-cover grayscale-[15%] contrast-[105%]\"\n              />\n\n              {/* Floating Instagram counter badge */}\n              <a\n                href=\"https://instagram.com\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                className=\"absolute bottom-6 right-6 bg-cream text-plum p-4 rounded-xl border border-plum/15 shadow-[0_8px_30px_rgba(33,20,38,0.08)] flex items-center gap-3 transition-transform hover:scale-105\"\n              >\n                <div className=\"p-2.5 bg-plum text-cream rounded-full\">\n                  <Instagram className=\"w-4 h-4 text-cream\" />\n                </div>\n                <div className=\"text-left font-sans\">\n                  <p className=\"text-[10px] uppercase tracking-widest text-mauve font-semibold leading-none\">\n                    INSTAGRAM COMMUNITY\n                  </p>\n                  <p className=\"font-serif text-lg leading-tight text-plum mt-1\">\n                    @MummasCake\n                  </p>\n                </div>\n              </a>\n            </div>\n\n            {/* Overlapping small circular craft seal */}\n            <div className=\"absolute -top-6 -right-4 bg-plum text-cream text-[9px] font-bold uppercase tracking-[0.2em] rounded-full w-24 h-24 flex items-center justify-center p-3 text-center border-4 border-cream rotate-12\">\n              ESTD. 2018\n            </div>\n          </div>\n\n          {/* Right Column: Founder Story, Vision and Sign-off */}\n          <div className=\"lg:col-span-7 flex flex-col items-start text-left order-1 lg:order-2\">\n            <span className=\"text-xs font-semibold uppercase tracking-[0.25em] text-mauve font-sans block mb-3\">\n              \342\234\246 MEET THE FOUNDER\n            </span>\n            <h2 className=\"font-serif text-4xl sm:text-5xl md:text-6xl font-normal leading-tight text-plum tracking-tight\">\n              Spatulas, Chemistry,<br />and Six-Figure Success.\n            </h2>\n\n            <p className=\"mt-8 text-sm md:text-base font-light text-plum/85 leading-relaxed font-sans space-y-4\">\n              <span className=\"block\">\n                I am <strong>Mahek Baldota</strong>, the founder of <strong>Mumma\'s Cake</strong>. My culinary saga started in a cramped home kitchen, armed with a single piping bag and an obsession with texture. I spent four years deconstructing traditional sponge cake ratios to design a structure that doesn\'t sink under premium heavy buttercreams.\n              </span>\n              <span className=\"block\">\n                After serving thousands of high-profile local clients and seeing my custom palette-knife floral creations go viral on Instagram, I realized my true purpose: <strong>empowering other bakers to escape the low-price custom cake trap.</strong>\n              </span>\n              <span className=\"block\">\n                Today, our academy manages a thriving directory of <strong>30,000+ graduates globally</strong>, teaching them the precise science of crumb structure paired with elite luxury business blueprints to launch sustainable, high-margin baking brands.\n              </span>\n            </p>\n\n            {/* Elite credentials checklist rows */}\n            <div className=\"mt-10 grid grid-cols-1 md:grid-cols-2 gap-6 w-full border-t border-plum/10 pt-8 font-sans\">\n              <div className=\"flex gap-4\">\n                <div className=\"shrink-0 w-6 h-6 rounded-full bg-plum/5 flex items-center justify-center\">\n                  <Star className=\"w-3.5 h-3.5 text-plum fill-plum\" />\n                </div>\n                <div>\n                  <h4 className=\"text-xs font-semibold uppercase tracking-wider text-plum\">\n                    Science-First Formulas\n                  </h4>\n                  <p className=\"text-xs font-light text-plum/70 mt-1\">\n                    No culinary hand-waving here. Every recipe is expressed in precise bakers\' percentages and temperature curves.\n                  </p>\n                </div>\n              </div>\n\n              <div className=\"flex gap-4\">\n                <div className=\"shrink-0 w-6 h-6 rounded-full bg-plum/5 flex items-center justify-center\">\n                  <Award className=\"w-3.5 h-3.5 text-plum fill-plum\" />\n                </div>\n                <div>\n                  <h4 className=\"text-xs font-semibold uppercase tracking-wider text-plum\">\n                    Awwwarded Business Logic\n                  </h4>\n                  <p className=\"text-xs font-light text-plum/70 mt-1\">\n                    We cover margin shielding, custom contract templates, and influencer marketing loops to scale without overheads.\n                  </p>\n                </div>\n              </div>\n            </div>\n\n            {/* Human Signature block */}\n            <div className=\"mt-12 flex items-center gap-4\">\n              <div className=\"text-left font-serif\">\n                <p className=\"text-2xl italic tracking-tight text-plum\">Mahek Baldota</p>\n                <p className=\"text-[10px] uppercase tracking-widest text-mauve font-semibold font-sans mt-0.5\">\n                  Founder & Principal Instructor, Mumma\'s Cake\n                </p>\n              </div>\n            </div>\n\n          </div>\n\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    }
