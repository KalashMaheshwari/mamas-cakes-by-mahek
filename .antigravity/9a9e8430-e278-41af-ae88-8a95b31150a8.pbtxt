    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { useState } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { Sparkles, ArrowUpRight, Award, Camera, Palette, Shield } from \"lucide-react\";\n\ninterface Masterpiece {\n  id: string;\n  name: string;\n  technique: string;\n  description: string;\n  image: string;\n  highlightColor: string;\n  timeToSculpt: string;\n  difficulty: string;\n}\n\nconst MASTERPIECES: Masterpiece[] = [\n  {\n    id: \"bloom\",\n    name: \"Impasto Palette-Knife Bloom\",\n    technique: \"Buttercream Sculpture\",\n    description: \"Our signature technique using organic cold butter emulsified to exactly 21.5\302\260C. Layered with heavy buttercream petals that mimic classic oil paintings. Designed to hold perfect petal crispness even in tropical climates.\",\n    image: \"https://images.unsplash.com/photo-1535141192574-5d4897c13636?q=80&w=800&auto=format&fit=crop\",\n    highlightColor: \"#80173F\",\n    timeToSculpt: \"6 Hours\",\n    difficulty: \"Advanced Mastery\"\n  },\n  {\n    id: \"gilded\",\n    name: \"Architectural Gilded Concrete\",\n    technique: \"Ganache Structural Vault\",\n    description: \"A stark, modern structure with fine metallic crust lines. Formulated with triple-tempered Belgian dark chocolate whipped at 85% hydration, achieving stone-like texture with smooth, melt-in-the-mouth cocoa notes.\",\n    image: \"https://images.unsplash.com/photo-1542826438-bd32f43d626f?q=80&w=800&auto=format&fit=crop\",\n    highlightColor: \"#DCAE1D\",\n    timeToSculpt: \"8 Hours\",\n    difficulty: \"Elite Level\"\n  },\n  {\n    id: \"velvet\",\n    name: \"Macaron Tower & Pistachio Spray\",\n    technique: \"Velvet Cocoa Spray & Footing\",\n    description: \"A vibrant, raspberry and pistachio micro-textured matte shell enclosing high-altitude roasted nut ganache. Explores standard airflow mechanics and the exact Italian meringue ribbon flow.\",\n    image: \"https://images.unsplash.com/photo-1578985545062-69928b1d9587?q=80&w=800&auto=format&fit=crop\",\n    highlightColor: \"#4E6E58\",\n    timeToSculpt: \"4 Hours\",\n    difficulty: \"Intermediate Base\"\n  }\n];\n\nexport default function CakeArtistryShowcase() {\n  const [activeId, setActiveId] = useState<string>(\"bloom\");\n  const current = MASTERPIECES.find(m => m.id === activeId) || MASTERPIECES[0];\n\n  return (\n    <section id=\"artistry-showcase\" className=\"py-24 md:py-32 bg-cream relative overflow-hidden\">\n      {/* Editorial glowing accents */}\n      <div className=\"absolute top-0 right-1/4 w-[600px] h-[600px] bg-[#FFF2CD] rounded-full filter blur-[120px] opacity-40 pointer-events-none\" />\n      <div className=\"absolute bottom-10 left-10 w-[450px] h-[450px] bg-mauve/10 rounded-full filter blur-[100px] opacity-30 pointer-events-none\" />\n\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12\">\n        {/* Section Title */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-end mb-16 md:mb-24\">\n          <div className=\"lg:col-span-8 text-left\">\n            <span className=\"text-xs font-semibold uppercase tracking-[0.3em] text-[#80173F] bg-[#80173F]/5 px-3 py-1.5 rounded-full inline-block mb-4 font-sans\">\n              \342\234\246 CULINARY ARTISTRY EXHIBIT\n            </span>\n            <h2 className=\"font-serif text-5xl sm:text-6xl md:text-7xl font-normal leading-tight text-plum tracking-tight\">\n              We Sculpt Masterpieces.<br />\n              We Teach the Science.\n            </h2>\n          </div>\n          <div className=\"lg:col-span-4 text-left lg:text-right\">\n            <p className=\"text-base font-light text-plum/80 font-sans leading-relaxed\">\n              Every course is backed by hundreds of live wedding commissions and signature techniques crafted by Mahek. Explore the architectural depth we teach in our masterclasses.\n            </p>\n          </div>\n        </div>\n\n        {/* Exhibition Frame */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          {/* Left Column: List/Tabs & Storytelling */}\n          <div className=\"lg:col-span-5 flex flex-col gap-6 text-left order-2 lg:order-1\">\n            <span className=\"text-[10px] font-bold uppercase tracking-[0.2em] text-mauve font-sans block\">\n              \342\200\224 CLICK AN EXHIBIT TO VIEW TECHNIQUE\n            </span>\n            \n            <div className=\"space-y-4\">\n              {MASTERPIECES.map((piece) => {\n                const isActive = piece.id === activeId;\n                return (\n                  <button\n                    key={piece.id}\n                    onClick={() => setActiveId(piece.id)}\n                    className={`w-full p-6 rounded-2xl border text-left transition-all duration-500 cursor-pointer ${\n                      isActive\n                        ? \"bg-surface-white border-[#80173F] shadow-[0_20px_40px_-15px_rgba(128,23,63,0.08)] scale-[1.01]\"\n                        : \"bg-transparent border-plum/10 hover:border-plum\"\n                    }`}\n                  >\n                    <div className=\"flex justify-between items-start\">\n                      <div>\n                        <h4 className=\"font-serif text-2xl text-plum leading-tight\">\n                          {piece.name}\n                        </h4>\n                        <p className=\"text-xs text-mauve font-sans mt-1\">\n                          {piece.technique}\n                        </p>\n                      </div>\n                      <span className=\"text-[10px] font-mono bg-plum/5 text-plum px-3 py-1 rounded-full uppercase\">\n                        {piece.difficulty}\n                      </span>\n                    </div>\n\n                    <AnimatePresence>\n                      {isActive && (\n                        <motion.div\n                          initial={{ opacity: 0, height: 0 }}\n                          animate={{ opacity: 1, height: \"auto\" }}\n                          exit={{ opacity: 0, height: 0 }}\n                          transition={{ duration: 0.3 }}\n                          className=\"mt-4 pt-4 border-t border-plum/10 space-y-3\"\n                        >\n                          <p className=\"text-xs font-light text-plum/80 leading-relaxed font-sans\">\n                            {piece.description}\n                          </p>\n                          \n                          <div className=\"flex gap-6 pt-2 text-[11px] font-mono text-plum/60\">\n                            <span className=\"flex items-center gap-1.5\">\n                              <Award className=\"w-3.5 h-3.5 text-[#80173F]\" />\n                              {piece.timeToSculpt} Process\n                            </span>\n                            <span className=\"flex items-center gap-1.5\">\n                              <Palette className=\"w-3.5 h-3.5 text-mauve\" />\n                              Color Mixing Secret Inside\n                            </span>\n                          </div>\n                        </motion.div>\n                      )}\n                    </AnimatePresence>\n                  </button>\n                );\n              })}\n            </div>\n          </div>\n\n          {/* Right Column: High-texture Image Display frame */}\n          <div className=\"lg:col-span-7 relative order-1 lg:order-2\">\n            <div className=\"absolute -inset-2 border border-plum/10 rounded-3xl pointer-events-none z-10\" />\n            <div className=\"aspect-[4/3] w-full bg-plum/5 rounded-2xl overflow-hidden shadow-[0_30px_60px_-15px_rgba(33,20,38,0.1)] relative\">\n              <AnimatePresence mode=\"wait\">\n                <motion.img\n                  key={current.id}\n                  initial={{ scale: 1.1, opacity: 0 }}\n                  animate={{ scale: 1, opacity: 1 }}\n                  exit={{ scale: 1.05, opacity: 0 }}\n                  transition={{ duration: 0.8, ease: [0.76, 0, 0.24, 1] }}\n                  src={current.image}\n                  alt={current.name}\n                  referrerPolicy=\"no-referrer\"\n                  className=\"absolute inset-0 w-full h-full object-cover\"\n                />\n              </AnimatePresence>\n\n              {/* Technique tag badge overlays */}\n              <div className=\"absolute bottom-6 left-6 right-6 z-20 flex justify-between items-center bg-cream/90 backdrop-blur-md px-6 py-4 rounded-xl border border-plum/10\">\n                <div className=\"text-left\">\n                  <p className=\"text-[9px] font-sans font-bold uppercase tracking-wider text-mauve leading-none\">\n                    ACTIVE TECHNIQUE\n                  </p>\n                  <p className=\"font-serif text-lg text-plum mt-1\">\n                    {current.technique}\n                  </p>\n                </div>\n                <div className=\"flex items-center gap-1.5 text-xs font-semibold text-[#80173F] font-sans uppercase\">\n                  <span>Elite Class Course</span>\n                  <ArrowUpRight className=\"w-4 h-4\" />\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Bottom Callout Frame about cake science */}\n        <div className=\"mt-20 p-8 md:p-12 border border-plum/10 rounded-2xl bg-surface-white text-left grid grid-cols-1 md:grid-cols-3 gap-8\">\n          <div className=\"flex gap-4 items-start\">\n            <div className=\"p-3 rounded-xl bg-plum/5 text-plum shrink-0\">\n              <Award className=\"w-6 h-6 text-[#80173F]\" />\n            </div>\n            <div>\n              <h4 className=\"font-serif text-lg text-plum font-normal mb-1\">\n                Zero Box Mixes\n              </h4>\n              <p className=\"text-xs font-light text-plum/70 font-sans leading-relaxed\">\n                Learn core starch gelation at precisely 92\302\260C to craft airy vanilla sponges capable of carrying 3kg custom sculptural weights safely.\n              </p>\n            </div>\n          </div>\n\n          <div className=\"flex gap-4 items-start\">\n            <div className=\"p-3 rounded-xl bg-plum/5 text-plum shrink-0\">\n              <Camera className=\"w-6 h-6 text-[#80173F]\" />\n            </div>\n            <div>\n              <h4 className=\"font-serif text-lg text-plum font-normal mb-1\">\n                Viral Aesthetic Setup\n              </h4>\n              <p className=\"text-xs font-light text-plum/70 font-sans leading-relaxed\">\n                Step-by-step styling rules on using light diffusions, camera exposure, and macro lenses to trigger rapid organic views on Reels.\n              </p>\n            </div>\n          </div>\n\n          <div className=\"flex gap-4 items-start\">\n            <div className=\"p-3 rounded-xl bg-plum/5 text-[#80173F] shrink-0\">\n              <Shield className=\"w-6 h-6 text-[#80173F]\" />\n            </div>\n            <div>\n              <h4 className=\"font-serif text-lg text-plum font-normal mb-1\">\n                Luxury Price Locking\n              </h4>\n              <p className=\"text-xs font-light text-plum/70 font-sans leading-relaxed\">\n                Blueprints on crafting brand perception that locks out discount buyers and anchor-packs commissions from \342\202\2714,000 to \342\202\27112,000 per cake.\n              </p>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
