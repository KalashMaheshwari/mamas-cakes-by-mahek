  file_change {
    absolute_path_uri: "file:///src/components/Testimonials.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { motion } from \"motion/react\";\nimport { Star, CheckCircle2, Quote, Sparkles, TrendingUp, Sparkle } from \"lucide-react\";\nimport { Testimonial } from \"../types\";\n\nconst ROW_ONE_REVIEWS: Testimonial[] = [\n  {\n    id: \"review-1\",\n    studentName: \"Shruti Mehta\",\n    businessName: \"The Flour Garden, Mumbai\",\n    quote: \"Mahek\'s business blueprint was the absolute turning point for me. I went from selling single-tiered cakes from my home for \342\202\2711,200 to licensing a real boutique kitchen and charging \342\202\27112,000+ per bespoke order. Absolute masterpiece of scaling!\",\n    achievement: \"\342\202\2711.5L/month in 8 months\",\n    rating: 5\n  },\n  {\n    id: \"review-2\",\n    studentName: \"Ananya Iyer\",\n    businessName: \"Gilded Whisk Pastry, Chennai\",\n    quote: \"The concrete texturing and palette-knife courses are unbelievably detailed. Most tutorials show pretty parts; Mahek teaches the chemical kinetics of heavy buttercream surviving 40-degree shipping heat. Truly game-changing.\",\n    achievement: \"Won Custom Baker Award\",\n    rating: 5\n  },\n  {\n    id: \"review-3\",\n    studentName: \"Priyanka Patel\",\n    businessName: \"Bakehouse Co., Bangalore\",\n    quote: \"Baking is 50% science and 50% operations. Mumma\'s Cake is the first that actually teaches contract drafting and booking-fee structures. I am now managing 4 corporate dessert catering accounts safely!\",\n    achievement: \"Secured corporate retainer agreements\",\n    rating: 5\n  },\n  {\n    id: \"review-4\",\n    studentName: \"Kavita Sen\",\n    businessName: \"Rustic Crumb, Delhi\",\n    quote: \"The Artisanal Sourdough and Sponge classes changed everything. Clients keep telling me my sponge is the absolute most velvety they have ever tasted, moist without cloying chemical syrup. Proud alumna!\",\n    achievement: \"48-hour order waitlist\",\n    rating: 5\n  }\n];\n\nconst ROW_TWO_REVIEWS: Testimonial[] = [\n  {\n    id: \"review-5\",\n    studentName: \"Meera Oberoi\",\n    businessName: \"Velvet Swirl Studio, Pune\",\n    quote: \"The sharp edges theory changed how I view ganache. I used to spend hours smoothing structures with heat spatulas; now I lock the structural matrix in exactly 20 minutes. My productivity tripled!\",\n    achievement: \"Cut prep time by 60%\",\n    rating: 5\n  },\n  {\n    id: \"review-6\",\n    studentName: \"Devika Sharma\",\n    businessName: \"The Vanilla Pod, Kolkata\",\n    quote: \"I bought the Business Launchpad course, and it paid itself back in precisely 4 days. Her templates on customer relationship systems and automated order forms saved me days of manual paperwork.\",\n    achievement: \"100% automated booking system\",\n    rating: 5\n  },\n  {\n    id: \"review-7\",\n    studentName: \"Zoya Malik\",\n    businessName: \"Crust & Caramel, Hyderabad\",\n    quote: \"The level of support in the private student discord is unmatched! Mahek personally reviewed my palette floral work and suggested the exact stabilizer adjustments. My cakes look like oil paintings now.\",\n    achievement: \"Active 50K reels view avg\",\n    rating: 5\n  },\n  {\n    id: \"review-8\",\n    studentName: \"Riya Fernandez\",\n    businessName: \"The Frosted Bloom, Goa\",\n    quote: \"Being a non-egg baker, I was highly skeptical about premium gluten matrices. These recipes deliver perfect spring rate and velvet core hydration in egg-free sponges. Clients are utterly amazed.\",\n    achievement: \"Sells out every wedding season\",\n    rating: 5\n  }\n];\n\nexport default function Testimonials() {\n  return (\n    <section id=\"reviews\" className=\"py-24 md:py-32 bg-[#FFFDF7] border-t border-plum/10 relative overflow-hidden\">\n      {/* Editorial glowing vibrant accents */}\n      <div className=\"absolute top-1/4 left-1/10 w-[500px] h-[500px] bg-[#FFD6E8] rounded-full filter blur-[130px] opacity-25 pointer-events-none\" />\n      <div className=\"absolute bottom-1/4 right-1/10 w-[450px] h-[450px] bg-[#FFF2CD] rounded-full filter blur-[125px] opacity-30 pointer-events-none\" />\n\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12 mb-12\">\n        {/* Section Header */}\n        <div className=\"text-left max-w-3xl\">\n          <span className=\"text-xs font-bold uppercase tracking-[0.3em] text-[#80173F] bg-[#80173F]/5 px-3 py-1.5 rounded-full inline-block mb-4 font-sans\">\n            \342\234\246 HIGH-IMPACT ALUMNAE RADAR\n          </span>\n          <h2 className=\"font-serif text-5xl sm:text-6xl md:text-7xl font-normal leading-tight text-plum tracking-tight\">\n            Proof in the Batter.<br />\n            Loved by 30,000+ Students.\n          </h2>\n          <p className=\"mt-4 text-base md:text-lg font-light text-plum/70 font-sans leading-relaxed max-w-2xl\">\n            From kitchen hobbyists to thriving physical boutique bakery studio owners, our global alumae network proof-tests Mumma\'s formulas. Hover to pause and read.\n          </p>\n        </div>\n      </div>\n\n      {/* Continuously Horizontally Scrolling Lanes Container */}\n      <div className=\"flex flex-col gap-6 md:gap-8 overflow-hidden select-none relative py-4\">\n        {/* Top Fade overlay layers to make scrolling feel organic */}\n        <div className=\"absolute left-0 top-0 bottom-0 w-16 md:w-40 bg-gradient-to-r from-[#FFFDF7] to-transparent z-20 pointer-events-none\" />\n        <div className=\"absolute right-0 top-0 bottom-0 w-16 md:w-40 bg-gradient-to-l from-[#FFFDF7] to-transparent z-20 pointer-events-none\" />\n\n        {/* Row 1: Scrolling Left */}\n        <div className=\"flex w-max\">\n          <motion.div\n            animate={{ x: [0, \"-50%\"] }}\n            transition={{\n              ease: \"linear\",\n              duration: 38,\n              repeat: Infinity,\n            }}\n            className=\"flex gap-6 pr-6 w-max\"\n          >\n            {/* Array duplicated to ensure seamless infinite looping */}\n            {[...ROW_ONE_REVIEWS, ...ROW_ONE_REVIEWS].map((rev, idx) => (\n              <TestimonialCard key={`${rev.id}-${idx}`} review={rev} cardColor=\"cherry\" />\n            ))}\n          </motion.div>\n        </div>\n\n        {/* Row 2: Scrolling Right */}\n        <div className=\"flex w-max\">\n          <motion.div\n            animate={{ x: [\"-50%\", \"0%\"] }}\n            transition={{\n              ease: \"linear\",\n              duration: 42,\n              repeat: Infinity,\n            }}\n            className=\"flex gap-6 pr-6 w-max\"\n          >\n            {[...ROW_TWO_REVIEWS, ...ROW_TWO_REVIEWS].map((rev, idx) => (\n              <TestimonialCard key={`${rev.id}-${idx}`} review={rev} cardColor=\"apricot\" />\n            ))}\n          </motion.div>\n        </div>\n      </div>\n\n      {/* Decorative Bottom counter stats */}\n      <div className=\"max-w-7xl mx-auto px-6 md:px-12 mt-16 flex flex-wrap justify-between items-center gap-6 border-t border-plum/10 pt-10\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"w-10 h-10 rounded-full bg-[#80173F]/10 flex items-center justify-center text-[#80173F]\">\n            <TrendingUp className=\"w-5 h-5\" />\n          </div>\n          <div className=\"text-left\">\n            <p className=\"text-[10px] font-sans font-bold uppercase tracking-wider text-mauve\">ALUMNA RETOUR RATE</p>\n            <p className=\"font-serif text-lg text-plum leading-none mt-1\">94% Career Pivot Rate</p>\n          </div>\n        </div>\n\n        <div className=\"flex items-center gap-3\">\n          <div className=\"w-10 h-10 rounded-full bg-[#DCAE1D]/10 flex items-center justify-center text-[#DCAE1D]\">\n            <Sparkle className=\"w-5 h-5 fill-[#DCAE1D]\" />\n          </div>\n          <div className=\"text-left\">\n            <p className=\"text-[10px] font-sans font-bold uppercase tracking-wider text-mauve\">TOTAL IMPRESSIONS CREATED</p>\n            <p className=\"font-serif text-lg text-plum leading-none mt-1\">120M+ Social Views Generated</p>\n          </div>\n        </div>\n\n        <div className=\"flex items-center gap-3\">\n          <div className=\"w-10 h-10 rounded-full bg-[#4E6E58]/10 flex items-center justify-center text-[#4E6E58]\">\n            <CheckCircle2 className=\"w-5 h-5\" />\n          </div>\n          <div className=\"text-left\">\n            <p className=\"text-[10px] font-sans font-bold uppercase tracking-wider text-mauve\">CURRICULUM SECURITY</p>\n            <p className=\"font-serif text-lg text-plum leading-none mt-1\">Govt. Verified Formulas</p>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}\n\ninterface CardProps {\n  review: Testimonial;\n  cardColor: \"cherry\" | \"apricot\";\n}\n\nfunction TestimonialCard({ review, cardColor }: CardProps) {\n  // Generate random initials background or fallback\n  const initials = review.studentName\n    .split(\" \")\n    .map((word) => word[0])\n    .join(\"\");\n\n  const bgStyle =\n    cardColor === \"cherry\"\n      ? \"hover:border-[#80173F]/40 hover:shadow-[0_15px_35px_rgba(128,23,63,0.06)]\"\n      : \"hover:border-[#DCAE1D]/50 hover:shadow-[0_15px_35px_rgba(220,174,29,0.06)]\";\n\n  const initialsColor =\n    cardColor === \"cherry\"\n      ? \"bg-[#80173F]/10 text-[#80173F]\"\n      : \"bg-[#DCAE1D]/15 text-[#80173F]\";\n\n  const accentPill =\n    cardColor === \"cherry\"\n      ? \"bg-[#80173F]/5 text-[#80173F] border-[#80173F]/10\"\n      : \"bg-[#DCAE1D]/5 text-[#80173F] border-[#DCAE1D]/10\";\n\n  return (\n    <motion.div\n      whileHover={{ y: -5, scale: 1.01 }}\n      transition={{ duration: 0.3 }}\n      className={`w-[290px] sm:w-[360px] flex-shrink-0 bg-surface-white border border-plum/10 rounded-2xl p-6 md:p-8 flex flex-col justify-between text-left transition-all duration-300 ${bgStyle} cursor-pointer shadow-[0_10px_30px_rgba(33,20,38,0.02)] relative overflow-hidden`}\n    >\n      {/* Decorative quote mark */}\n      <div className=\"absolute right-4 top-4 text-plum/5 pointer-events-none\">\n        <Quote className=\"w-12 h-12 stroke-[1]\" />\n      </div>\n\n      <div className=\"space-y-4\">\n        {/* Multi-star high authority row */}\n        <div className=\"flex items-center justify-between\">\n          <div className=\"flex items-center gap-1\">\n            {[...Array(5)].map((_, i) => (\n              <Star key={i} className=\"w-3.5 h-3.5 fill-[#DCAE1D] text-[#DCAE1D]\" />\n            ))}\n          </div>\n          <div className=\"flex items-center gap-1 text-[9px] font-mono font-bold uppercase tracking-wider text-mauve\">\n            <CheckCircle2 className=\"w-3.5 h-3.5 text-[#4E6E58]\" /> Verified Alum\n          </div>\n        </div>\n\n        {/* The Quote review content */}\n        <p className=\"text-xs sm:text-sm font-light text-plum/85 leading-relaxed font-sans italic\">\n          \"{review.quote}\"\n        </p>\n      </div>\n\n      {/* Separator line */}\n      <div className=\"pt-5 mt-5 border-t border-plum/8 flex items-center gap-3\">\n        {/* Round profile image circle placeholder with stylish initials */}\n        <div className={`w-10 h-10 rounded-full font-serif text-sm font-semibold flex items-center justify-center shrink-0 ${initialsColor}`}>\n          {initials}\n        </div>\n        \n        <div className=\"min-w-0 flex-1\">\n          <h4 className=\"font-serif text-base text-plum truncate leading-tight\">\n            {review.studentName}\n          </h4>\n          <p className=\"text-[10px] font-medium tracking-wide text-mauve truncate font-sans mt-0.5\">\n            {review.businessName}\n          </p>\n        </div>\n      </div>\n\n      {/* Micro Badge for the actual concrete success stat */}\n      <div className={`mt-4 px-3 py-1.5 rounded-lg border text-[9px] font-mono uppercase tracking-wider flex items-center gap-1.5 w-max ${accentPill}`}>\n        <Sparkles className=\"w-3 h-3 shrink-0\" />\n        <span className=\"truncate\">{review.achievement}</span>\n      </div>\n    </motion.div>\n  );\n}\n"
    }
