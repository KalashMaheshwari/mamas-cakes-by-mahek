  file_change {
    absolute_path_uri: "file:///src/components/Footer.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { Instagram, Youtube, Compass, ArrowUp, Heart } from \"lucide-react\";\n\nexport default function Footer() {\n  const handleScrollTop = () => {\n    window.scrollTo({\n      top: 0,\n      behavior: \"smooth\"\n    });\n  };\n\n  const scrollToId = (id: string) => {\n    const el = document.getElementById(id);\n    if (el) {\n      const topOffset = el.getBoundingClientRect().top + window.scrollY - 80;\n      window.scrollTo({ top: topOffset, behavior: \"smooth\" });\n    }\n  };\n\n  return (\n    <footer className=\"bg-plum text-cream pt-20 pb-12 px-6 md:px-12 lg:px-24 border-t border-cream/5 relative z-20 overflow-hidden select-none\">\n      \n      {/* Editorial Grid */}\n      <div className=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-12 pb-16 border-b border-cream/10\">\n        \n        {/* Column 1: Brand & Logo Paragraph (col span 5) */}\n        <div className=\"md:col-span-5 flex flex-col items-start text-left\">\n          <span className=\"font-serif text-3xl font-light text-cream tracking-tight block\">\n            Mumma\'s Cake\n          </span>\n          <span className=\"text-[10px] uppercase tracking-[0.25em] text-mauve block mt-1 font-sans\">\n            by Mahek Baldota\n          </span>\n          \n          <p className=\"mt-6 text-sm font-light text-cream/70 leading-relaxed max-w-[34ch] font-sans\">\n            A premium dual digital culinary academy and handcrafted gourmet bakery designed for ambitious chefs, home bakers, and confectionary entrepreneurs globally.\n          </p>\n\n          <div className=\"mt-8 flex gap-4\">\n            <a\n              href=\"https://instagram.com\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"p-2.5 bg-cream/5 hover:bg-cream/15 text-cream hover:text-mauve rounded-full transition-all duration-300\"\n              placeholder=\"Instagram Profile\"\n            >\n              <Instagram className=\"w-4 h-4\" />\n            </a>\n            <a\n              href=\"https://youtube.com\"\n              target=\"_blank\"\n              rel=\"noreferrer\"\n              className=\"p-2.5 bg-cream/5 hover:bg-cream/15 text-cream hover:text-mauve rounded-full transition-all duration-300\"\n              placeholder=\"YouTube Channel\"\n            >\n              <Youtube className=\"w-4 h-4\" />\n            </a>\n          </div>\n        </div>\n\n        {/* Column 2: Sitemap Navigation links (col span 3) */}\n        <div className=\"md:col-span-3 flex flex-col items-start text-left\">\n          <p className=\"text-[11px] font-bold uppercase tracking-[0.2em] text-mauve font-sans mb-6\">\n            \342\234\246 SITE DIRECTORY\n          </p>\n\n          <address className=\"not-italic space-y-4 font-sans text-xs flex flex-col items-start\">\n            <button\n              onClick={() => scrollToId(\"academy\")}\n              className=\"text-cream/85 hover:text-mauve transition-colors py-0.5\"\n            >\n              The Culinary Academy\n            </button>\n            <button\n              onClick={() => scrollToId(\"bakery\")}\n              className=\"text-cream/85 hover:text-mauve transition-colors py-0.5\"\n            >\n              Live Fresh Bakery\n            </button>\n            <button\n              onClick={() => scrollToId(\"about-mahek\")}\n              className=\"text-cream/85 hover:text-mauve transition-colors py-0.5\"\n            >\n              The Founder\'s Journey\n            </button>\n            <button\n              onClick={() => scrollToId(\"reviews\")}\n              className=\"text-cream/85 hover:text-mauve transition-colors py-0.5\"\n            >\n              Alumna Graduate Reviews\n            </button>\n            <button\n              onClick={() => scrollToId(\"faq\")}\n              className=\"text-cream/85 hover:text-mauve transition-colors py-0.5\"\n            >\n              Frequently Clarified\n            </button>\n          </address>\n        </div>\n\n        {/* Column 3: Headquarters Address (col span 4) */}\n        <div className=\"md:col-span-4 flex flex-col items-start text-left\">\n          <p className=\"text-[11px] font-bold uppercase tracking-[0.2em] text-mauve font-sans mb-6\">\n            \342\234\246 MUMBAI HEADQUARTERS\n          </p>\n          \n          <div className=\"flex gap-3 leading-relaxed\">\n            <div className=\"p-1.5 bg-cream/5 rounded text-mauve mt-1 select-none\">\n              <MapPin />\n            </div>\n            <p className=\"text-xs font-light text-cream/70 font-sans\">\n              <strong>Mumma\'s Cake Studio.</strong><br />\n              Hill Road, Bandra West,<br />\n              Mumbai, Maharashtra \342\200\224 400050<br />\n              <span className=\"text-[10px] text-mauve font-bold uppercase tracking-wider block mt-2\">\n                \342\231\246 Visitors by curated invite only\n              </span>\n            </p>\n          </div>\n        </div>\n\n      </div>\n\n      {/* Fine-print Row at Bottom */}\n      <div className=\"max-w-7xl mx-auto pt-10 flex flex-col sm:flex-row items-center justify-between gap-6 font-sans text-[11px] text-cream/50\">\n        <p className=\"text-center sm:text-left leading-relaxed\">\n          \302\251 2026 Mumma\'s Cake Studio. Designed & custom-curated with <Heart className=\"w-3 h-3 text-mauve inline fill-mauve mx-0.5\" /> by Mahek Baldota.<br className=\"sm:hidden\" /> All global business rights reserved.\n        </p>\n\n        {/* Return to top arrow button */}\n        <button\n          onClick={handleScrollTop}\n          className=\"flex items-center gap-2 px-4 py-2 bg-cream/5 hover:bg-cream/15 text-cream hover:text-mauve transition-all duration-300 rounded-full border border-cream/5 cursor-pointer\"\n        >\n          <span>Return to Top</span>\n          <ArrowUp className=\"w-3 h-3 animate-bounce\" />\n        </button>\n      </div>\n\n    </footer>\n  );\n}\n\nfunction MapPin() {\n  return (\n    <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"w-4 h-4 text-mauve\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n      <path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\"></path>\n      <circle cx=\"12\" cy=\"10\" r=\"3\"></circle>\n    </svg>\n  );\n}\n"
    }
